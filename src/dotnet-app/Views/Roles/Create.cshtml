@model QualityDoc.API.Models.Role

@{
    ViewData["Title"] = "Registrar Nuevo Rol";
}

<div class="max-w-3xl mx-auto">
    <!-- Breadcrumb de navegación -->
    <nav class="flex mb-4 text-gray-500 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-blue-600 transition">Roles del Sistema</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-gray-400">Nuevo Rol</li>
        </ol>
    </nav>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <!-- Encabezado del Formulario -->
        <div class="bg-blue-50 border-b border-blue-100 p-6 flex items-center">
            <div class="bg-blue-600 text-white h-10 w-10 flex items-center justify-center rounded-lg text-lg mr-4 shadow-sm">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-blue-900">Registrar Nuevo Rol</h2>
                <p class="text-sm text-blue-700">Crea un nivel de acceso personalizado para la plataforma.</p>
            </div>
        </div>

        <!-- Cuerpo del Formulario -->
        <form asp-action="Create" class="p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded-lg border border-red-100 mb-4"></div>

            <!-- Nombre del Rol -->
            <div>
                <label asp-for="RoleName" class="block text-sm font-bold text-gray-700 mb-1">Nombre del Rol <span class="text-red-500">*</span></label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-user-tag text-gray-400"></i>
                    </div>
                    <input asp-for="RoleName" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" placeholder="Ej. Auditor Externo" required />
                </div>
                <span asp-validation-for="RoleName" class="text-xs text-red-500 mt-1 block"></span>
                <p class="text-xs text-gray-400 mt-2"><i class="fa-solid fa-circle-info mr-1"></i> Los roles maestros del sistema (Super Admin, Revisor, etc.) ya vienen predefinidos.</p>
            </div>

            <!-- Botones de Acción -->
            <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-100 mt-6">
                <a asp-action="Index" class="text-gray-500 hover:text-gray-800 font-medium text-sm px-4 py-2 rounded-lg hover:bg-gray-100 transition">
                    Cancelar
                </a>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg shadow-sm transition flex items-center">
                    <i class="fa-solid fa-floppy-disk mr-2"></i> Guardar Rol
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}