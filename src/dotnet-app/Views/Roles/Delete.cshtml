@model QualityDoc.API.Models.Role

@{
    ViewData["Title"] = "Suspender Rol Personalizado";
}

<div class="max-w-3xl mx-auto">
    <!-- Breadcrumb de navegación -->
    <nav class="flex mb-4 text-gray-500 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-blue-600 transition">Roles del Sistema</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-gray-400">Suspender Rol</li>
        </ol>
    </nav>

    <div class="bg-white rounded-xl shadow-sm border border-red-200 overflow-hidden">
        <!-- Encabezado de Advertencia -->
        <div class="bg-red-50 border-b border-red-100 p-6 flex items-center">
            <div class="bg-red-100 text-red-600 h-12 w-12 flex items-center justify-center rounded-full text-2xl mr-4 shadow-sm border border-red-200">
                <i class="fa-solid fa-user-xmark"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-red-900">¿Suspender este Rol Personalizado?</h2>
                <p class="text-sm text-red-700">Estás a punto de inactivar este nivel de acceso en la plataforma.</p>
            </div>
        </div>

        <!-- Mensaje de Información (UX para explicar el impacto) -->
        <div class="p-6 bg-yellow-50 border-b border-yellow-100 flex items-start">
            <i class="fa-solid fa-triangle-exclamation text-yellow-600 mt-0.5 mr-3"></i>
            <div class="text-sm text-yellow-800 leading-relaxed space-y-2">
                <p>
                    <strong>Aviso de Impacto:</strong> Al suspender este rol, cambiará su estado a <span class="font-bold">Inactivo</span>. 
                </p>
                <ul class="list-disc ml-5 text-yellow-700">
                    <li>Ya no aparecerá en las listas para asignar a nuevos usuarios.</li>
                    <li>Si hay usuarios que actualmente tienen este rol, podrían perder acceso a ciertas funciones del sistema.</li>
                </ul>
            </div>
        </div>

        <!-- Ficha Resumen de lo que se va a suspender -->
        <div class="p-8">
            <h3 class="text-sm font-bold text-gray-800 border-b border-gray-100 pb-2 mb-4">Datos del Rol a Suspender</h3>
            
            <div class="bg-gray-50 p-5 rounded-lg border border-gray-200">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <p class="text-xs text-gray-500 font-semibold uppercase mb-1">Nombre del Rol</p>
                        <p class="text-base font-bold text-gray-800">
                            <i class="fa-solid fa-user-tag text-purple-400 mr-2"></i>@Model.RoleName
                        </p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 font-semibold uppercase mb-1">Fecha de Creación</p>
                        <p class="text-base font-bold text-gray-800">
                            <i class="fa-regular fa-calendar mr-2 text-gray-400"></i>@Model.CreatedAt.ToString("dd MMM, yyyy")
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Formulario de Confirmación (Acciones) -->
        <div class="bg-gray-50 p-6 border-t border-gray-200 flex items-center justify-between">
            <a asp-action="Index" class="text-gray-600 hover:text-gray-900 font-medium text-sm px-4 py-2 rounded-lg hover:bg-gray-200 transition flex items-center">
                <i class="fa-solid fa-arrow-left mr-2"></i> Cancelar y volver
            </a>
            
            <form asp-action="Delete" method="post">
                <!-- 🚀 IMPORTANTE: El ID oculto para el POST -->
                <input type="hidden" asp-for="RoleId" />
                
                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-6 rounded-lg shadow-sm transition flex items-center">
                    <i class="fa-solid fa-power-off mr-2"></i> Sí, Suspender Rol
                </button>
            </form>
        </div>
    </div>
</div>