@model IEnumerable<QualityDoc.API.Models.Role>

@{
    ViewData["Title"] = "Roles del Sistema";
    // Lista de roles críticos para la lógica visual
    var systemRoles = new[] { "Super Admin", "Admin de Empresa", "Creador de Doc", "Revisor", "Aprobador", "Lector" };
}

<div class="space-y-6">
    <div class="flex justify-between items-end border-b border-gray-200 pb-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Roles del Sistema</h1>
            <p class="text-gray-500 text-sm">Gestión de permisos y niveles de acceso en la plataforma</p>
        </div>
        <div>
            <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold py-2 px-4 rounded-lg shadow-sm flex items-center transition duration-150">
                <i class="fa-solid fa-plus mr-2"></i> Nuevo Rol
            </a>
        </div>
    </div>

    <!-- 🚀 ALERTA DE ERROR DE SEGURIDAD (Si intentan borrar un rol maestro) -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-4 rounded-r-lg shadow-sm">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <i class="fa-solid fa-shield-halved text-red-500 text-xl"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-red-700 font-bold">
                        @TempData["ErrorMessage"]
                    </p>
                </div>
            </div>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-gray-50 text-gray-500 text-xs uppercase font-semibold">
                    <tr>
                        <th class="p-4">Nombre del Rol</th>
                        <th class="p-4 text-center">Estado</th>
                        <th class="p-4 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-sm">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="p-8 text-center text-gray-400">
                                <i class="fa-solid fa-users-slash text-3xl mb-2"></i>
                                <p>No hay roles registrados en el sistema.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            var isSystemRole = systemRoles.Contains(item.RoleName);

                            <tr class="hover:bg-gray-50 transition duration-150">
                                <td class="p-4 font-bold text-gray-800">
                                    <div class="flex items-center">
                                        <i class="fa-solid fa-user-tag text-purple-400 mr-2"></i> 
                                        @item.RoleName
                                        
                                        @if (isSystemRole)
                                        {
                                            <span class="ml-2 bg-blue-100 text-blue-700 text-[10px] uppercase font-bold px-2 py-0.5 rounded-full border border-blue-200" title="Rol crítico para el funcionamiento del sistema">
                                                <i class="fa-solid fa-shield-cat mr-1"></i> Sistema
                                            </span>
                                        }
                                    </div>
                                </td>

                                <td class="p-4 text-center">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="bg-green-100 text-green-700 px-2 py-1 rounded-full text-xs font-bold inline-flex items-center">
                                            <span class="w-2 h-2 bg-green-500 rounded-full mr-1.5"></span> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="bg-red-100 text-red-700 px-2 py-1 rounded-full text-xs font-bold inline-flex items-center">
                                            <span class="w-2 h-2 bg-red-500 rounded-full mr-1.5"></span> Inactivo
                                        </span>
                                    }
                                </td>
                                
                                <td class="p-4 text-center flex justify-center items-center space-x-4">
                                    
                                    <!-- Ver Detalles (Siempre Activo) -->
                                    <a asp-action="Details" asp-route-id="@item.RoleId" class="text-gray-400 hover:text-teal-600 transition" title="Ver Detalles">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>

                                    @if (item.Status == "Active")
                                    {
                                        <!-- Editar (Activo) -->
                                        <a asp-action="Edit" asp-route-id="@item.RoleId" class="text-gray-400 hover:text-blue-600 transition" title="Editar Rol">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <!-- Editar (Bloqueado) -->
                                        <span class="text-gray-300 cursor-not-allowed" title="Restaura el rol para poder editarlo">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </span>
                                    }
                                    
                                    @if (isSystemRole)
                                    {
                                        <!-- 🛡️ CANDADO PARA ROLES MAESTROS -->
                                        <span class="text-gray-300 cursor-not-allowed" title="Rol de sistema protegido (No se puede suspender)">
                                            <i class="fa-solid fa-lock"></i>
                                        </span>
                                    }
                                    else if (item.Status == "Active")
                                    {
                                        <!-- Suspender (POST) -->
                                        <form asp-action="Delete" asp-route-id="@item.RoleId" method="post" class="inline-block m-0 p-0">
                                            <button type="submit" class="text-gray-400 hover:text-red-600 transition bg-transparent border-none p-0 cursor-pointer" title="Suspender Rol" onclick="return confirm('¿Estás seguro de suspender este rol?');">
                                                <i class="fa-solid fa-power-off"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <!-- 🚀 BOTÓN REACTIVAR (POST) -->
                                        <form asp-action="Reactivate" asp-route-id="@item.RoleId" method="post" class="inline-block m-0 p-0">
                                            <button type="submit" class="text-gray-400 hover:text-green-600 transition bg-transparent border-none p-0 cursor-pointer" title="Reactivar Rol" onclick="return confirm('¿Estás seguro de que deseas reactivar este rol?');">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>