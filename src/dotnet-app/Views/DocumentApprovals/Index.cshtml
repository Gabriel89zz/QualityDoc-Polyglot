@model IEnumerable<QualityDoc.API.Models.DocumentApproval>
@using QualityDoc.API.Models

@{
    ViewData["Title"] = "Torre de Control";
    var drafts = ViewBag.Drafts as IEnumerable<DocumentVersion>;
    var creators = ViewBag.Creators as Dictionary<int, string>;
}

<div class="max-w-7xl mx-auto mt-4 space-y-8">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white dark:bg-[#323338] p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] transition-colors duration-300">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-white flex items-center">
                <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mr-3 border border-brand/20">
                    <i class="fa-solid fa-tower-broadcast text-brand"></i>
                </div>
                Torre de Control
            </h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Monitoreo global de documentos en redacción y flujos de aprobación.</p>
        </div>
    </div>

    <div>
        <h3 class="text-lg font-bold text-slate-800 dark:text-white mb-4 flex items-center">
            <i class="fa-solid fa-bars-progress text-amber-500 mr-2"></i> Flujos en Proceso
        </h3>
        <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-100 dark:divide-[#4a4b50]">
                    <thead class="bg-slate-50 dark:bg-[#2a2b2e] transition-colors duration-300">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Documento</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Departamento</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Paso Actual</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-red-500 dark:text-red-400 uppercase tracking-wider"><i class="fa-solid fa-clock mr-1"></i> Pendiente Con</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50] text-sm">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition-colors duration-150">
                                    <td class="px-6 py-4">
                                        <div class="text-sm font-black text-brand dark:text-brand-light">@item.DocumentVersion?.Document?.DocCode</div>
                                        <div class="text-sm font-semibold text-slate-700 dark:text-slate-300 max-w-xs truncate" title="@item.DocumentVersion?.Document?.DocName">
                                            @item.DocumentVersion?.Document?.DocName (v @item.DocumentVersion?.VersionNum)
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-slate-100 dark:bg-[#2a2b2e] text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-[#4a4b50] shadow-sm">
                                            @item.DocumentVersion?.Document?.Department?.DeptName
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-700 dark:text-slate-300 font-bold">
                                        <span class="bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-800/30 px-2 py-1 rounded-md text-xs">
                                            @item.StepOrder. @item.StepType
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="h-9 w-9 rounded-full bg-red-50 dark:bg-red-900/30 flex items-center justify-center text-red-600 dark:text-red-400 font-bold mr-3 border border-red-200 dark:border-red-800/50 shadow-sm">
                                                @item.Approver?.FullName.Substring(0, 1).ToUpper()
                                            </div>
                                            <div class="text-sm font-bold text-red-600 dark:text-red-400">
                                                @item.Approver?.FullName
                                                <div class="text-[10px] text-slate-500 dark:text-slate-400 font-semibold uppercase mt-0.5"><i class="fa-regular fa-clock mr-1"></i> Desde: @item.CreatedAt.ToLocalTime().ToString("dd/MMM/yy")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                        <a asp-controller="Documents" asp-action="Details" asp-route-id="@item.DocumentVersion?.DocId" class="text-slate-500 dark:text-slate-400 hover:text-brand dark:hover:text-brand-light px-4 py-2 bg-slate-100 dark:bg-[#2a2b2e] hover:bg-brand/10 dark:hover:bg-brand/20 rounded-lg transition font-bold shadow-sm">
                                            Ver Detalles <i class="fa-solid fa-arrow-right ml-1"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500">
                                    <div class="flex flex-col items-center justify-center">
                                        <div class="w-16 h-16 bg-slate-50 dark:bg-[#2a2b2e] rounded-full flex items-center justify-center mb-4 border border-slate-100 dark:border-[#4a4b50]">
                                            <i class="fa-solid fa-check-double text-2xl text-green-500 dark:text-green-400"></i>
                                        </div>
                                        <h3 class="text-base font-bold text-slate-800 dark:text-white">Cero cuellos de botella</h3>
                                        <p class="text-sm mt-1">Todos los flujos iniciados están al día y revisados.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div>
        <h3 class="text-lg font-bold text-slate-800 dark:text-white mb-4 flex items-center">
            <i class="fa-solid fa-file-pen text-brand mr-2"></i> Documentos en Borrador (Sin Iniciar)
        </h3>
        <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-100 dark:divide-[#4a4b50]">
                    <thead class="bg-slate-50 dark:bg-[#2a2b2e] transition-colors duration-300">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Documento</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Departamento</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-amber-600 dark:text-amber-500 uppercase tracking-wider"><i class="fa-solid fa-user-pen mr-1"></i> En redacción por</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50] text-sm">
                        @if (drafts != null && drafts.Any())
                        {
                            foreach (var draft in drafts)
                            {
                                int creatorId = draft.CreatedBy ?? 0;
                                string creatorName = creators != null && creators.ContainsKey(creatorId) ? creators[creatorId] : "Usuario Desconocido";
                                
                                <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition-colors duration-150">
                                    <td class="px-6 py-4">
                                        <div class="text-sm font-black text-brand dark:text-brand-light">@draft.Document?.DocCode</div>
                                        <div class="text-sm font-semibold text-slate-700 dark:text-slate-300 max-w-xs truncate" title="@draft.Document?.DocName">
                                            @draft.Document?.DocName (v @draft.VersionNum)
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-slate-100 dark:bg-[#2a2b2e] text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-[#4a4b50] shadow-sm">
                                            @draft.Document?.Department?.DeptName
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="h-9 w-9 rounded-full bg-amber-50 dark:bg-amber-900/30 flex items-center justify-center text-amber-600 dark:text-amber-400 font-bold mr-3 border border-amber-200 dark:border-amber-800/50 shadow-sm">
                                                @creatorName.Substring(0, 1).ToUpper()
                                            </div>
                                            <div class="text-sm font-bold text-amber-700 dark:text-amber-500">
                                                @creatorName
                                                <div class="text-[10px] text-slate-500 dark:text-slate-400 font-semibold uppercase mt-0.5"><i class="fa-regular fa-calendar-plus mr-1"></i> Creado: @draft.CreatedAt.ToLocalTime().ToString("dd/MMM/yy")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                        <a asp-controller="Documents" asp-action="Details" asp-route-id="@draft.DocId" class="text-slate-500 dark:text-slate-400 hover:text-brand dark:hover:text-brand-light px-4 py-2 bg-slate-100 dark:bg-[#2a2b2e] hover:bg-brand/10 dark:hover:bg-brand/20 rounded-lg transition font-bold shadow-sm">
                                            Ver Detalles <i class="fa-solid fa-arrow-right ml-1"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500">
                                    <div class="flex flex-col items-center justify-center">
                                        <div class="w-16 h-16 bg-slate-50 dark:bg-[#2a2b2e] rounded-full flex items-center justify-center mb-4 border border-slate-100 dark:border-[#4a4b50]">
                                            <i class="fa-solid fa-folder-open text-2xl text-slate-300 dark:text-slate-600"></i>
                                        </div>
                                        <h3 class="text-base font-bold text-slate-800 dark:text-white">Sin borradores activos</h3>
                                        <p class="text-sm mt-1">Todo el trabajo documental está ya en flujo de aprobación o publicado.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>