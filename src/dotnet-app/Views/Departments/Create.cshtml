@model QualityDoc.API.Models.Department

@{
    ViewData["Title"] = "Nuevo Departamento";
}

<div class="max-w-2xl mx-auto space-y-6">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-brand transition-colors">Departamentos</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Nuevo</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-brand/5 dark:bg-brand/10 border-b border-brand/10 dark:border-brand/20 p-6 flex items-center">
            <div class="bg-brand text-white h-10 w-10 flex items-center justify-center rounded-xl text-lg mr-4 shadow-sm shadow-brand/20">
                <i class="fa-solid fa-layer-group"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-brand dark:text-brand-light">Crear Departamento</h2>
                <p class="text-sm text-slate-600 dark:text-slate-400">Registra una nueva área para tu empresa.</p>
            </div>
        </div>

        <div class="p-8">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-transparent font-semibold"></div>

                <div class="mb-8">
                    <label asp-for="DeptName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nombre del Departamento <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                            <i class="fa-solid fa-sitemap"></i>
                        </div>
                        <input asp-for="DeptName" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white placeholder-slate-400 focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none" placeholder="Ej. Calidad, Producción, Recursos Humanos..." required autocomplete="off" />
                    </div>
                    <span asp-validation-for="DeptName" class="text-red-500 text-xs mt-1 block font-semibold"></span>
                </div>

                <div class="flex justify-end space-x-3 pt-6 border-t border-slate-100 dark:border-[#4a4b50] transition-colors duration-300">
                    <a asp-action="Index" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150">
                        Cancelar
                    </a>
                    <button type="submit" class="bg-brand hover:bg-brand-hover text-white text-sm font-bold py-2.5 px-6 rounded-xl shadow-md shadow-brand/20 flex items-center transition duration-150">
                        <i class="fa-solid fa-floppy-disk mr-2"></i> Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}