@model QualityDoc.API.Models.Department

@{
    ViewData["Title"] = "Editar Departamento";
}

<div class="max-w-2xl mx-auto space-y-6">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-brand transition-colors">Departamentos</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Modificar Registro</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-amber-50 dark:bg-amber-900/10 border-b border-amber-100 dark:border-amber-900/20 p-6">
            <div class="flex items-center">
                <div class="bg-amber-500 text-white h-10 w-10 flex items-center justify-center rounded-xl text-lg mr-4 shadow-sm shadow-amber-500/20">
                    <i class="fa-solid fa-pen-to-square"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-amber-900 dark:text-amber-400">Editar Departamento</h2>
                    <p class="text-sm text-amber-700 dark:text-amber-500/80">Actualiza la información del área seleccionada.</p>
                </div>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="p-8">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-transparent font-semibold"></div>
            
            <input type="hidden" asp-for="DeptId" />

            <div class="mb-6">
                <label asp-for="DeptName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nombre del Departamento</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                        <i class="fa-solid fa-sitemap"></i>
                    </div>
                    <input asp-for="DeptName" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white placeholder-slate-400 focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none" placeholder="Nombre del área..." required />
                </div>
                <span asp-validation-for="DeptName" class="text-red-500 text-xs mt-1 block font-semibold"></span>
            </div>

            <div class="mb-8">
                <label asp-for="Status" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Estado Operativo</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                        <i class="fa-solid fa-toggle-on"></i>
                    </div>
                    <select asp-for="Status" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none appearance-none">
                        <option value="Active">Activo</option>
                        <option value="Inactive">Inactivo / Suspendido</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-slate-400">
                        <i class="fa-solid fa-chevron-down text-xs"></i>
                    </div>
                </div>
                <span asp-validation-for="Status" class="text-red-500 text-xs mt-1 block font-semibold"></span>
            </div>

            <div class="flex justify-end space-x-3 pt-6 border-t border-slate-100 dark:border-[#4a4b50]">
                <a asp-action="Index" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150">
                    Descartar
                </a>
                <button type="submit" class="bg-amber-500 hover:bg-amber-600 text-white text-sm font-bold py-2.5 px-6 rounded-xl shadow-md shadow-amber-500/20 flex items-center transition duration-150">
                    <i class="fa-solid fa-rotate mr-2"></i> Actualizar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}