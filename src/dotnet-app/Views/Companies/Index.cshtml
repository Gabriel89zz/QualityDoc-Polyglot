@model IEnumerable<QualityDoc.API.Models.Company>

@{
    ViewData["Title"] = "Gestión de Empresas Clientes";
}

<div class="max-w-7xl mx-auto space-y-6 mt-4">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white dark:bg-[#323338] p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] transition-colors duration-300">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-white flex items-center">
                <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mr-3 border border-brand/20">
                    <i class="fa-solid fa-building text-brand"></i>
                </div>
                Empresas Clientes
            </h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Panel de administración global (Multi-tenant)</p>
        </div>
        <div class="mt-4 sm:mt-0">
            <a asp-action="Create" class="bg-brand hover:bg-brand-hover text-white font-bold py-2.5 px-5 rounded-xl shadow-md shadow-brand/20 flex items-center transition duration-200">
                <i class="fa-solid fa-plus mr-2"></i> Alta de Empresa
            </a>
        </div>
    </div>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50 dark:bg-[#2a2b2e] text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider transition-colors duration-300">
                    <tr>
                        <th class="p-4 font-semibold">Razón Social</th>
                        <th class="p-4 font-semibold">RFC / Tax ID</th>
                        <th class="p-4 font-semibold">Estado</th>
                        <th class="p-4 font-semibold">Fecha de Alta</th>
                        <th class="p-4 font-semibold text-center">Acciones</th>
                    </tr>
                </thead>
                
                <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50] text-sm">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="p-12 text-center text-slate-500 dark:text-slate-400">
                                <i class="fa-regular fa-building text-4xl mb-3 text-slate-300 dark:text-slate-600 block"></i>
                                <h5 class="text-lg font-bold text-slate-700 dark:text-slate-300 mb-1">Sin empresas registradas</h5>
                                <p class="text-sm">No hay empresas clientes dadas de alta en el sistema actualmente.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition duration-150">
                                <td class="p-4 font-bold text-slate-800 dark:text-white">
                                    <div class="flex items-center">
                                        <div class="h-8 w-8 rounded-lg bg-slate-100 dark:bg-[#2a2b2e] border border-slate-200 dark:border-[#4a4b50] flex items-center justify-center text-slate-500 dark:text-slate-400 mr-3 shadow-sm">
                                            <i class="fa-solid fa-briefcase text-xs"></i>
                                        </div>
                                        @item.LegalName
                                    </div>
                                </td>
                                
                                <td class="p-4 text-slate-600 dark:text-slate-400 font-mono text-xs font-semibold">
                                    <span class="bg-slate-100 dark:bg-[#2a2b2e] px-2 py-1 rounded border border-slate-200 dark:border-[#4a4b50]">
                                        @item.TaxId
                                    </span>
                                </td>
                                
                                <td class="p-4">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="inline-flex items-center bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 px-2.5 py-1 rounded-full text-xs font-bold border border-green-200 dark:border-green-800/30 w-max">
                                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1.5"></span> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 px-2.5 py-1 rounded-full text-xs font-bold border border-red-200 dark:border-red-800/30 w-max">
                                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full mr-1.5"></span> Inactivo
                                        </span>
                                    }
                                </td>
                                
                                <td class="p-4 text-slate-500 dark:text-slate-400 font-medium">
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </td>
                                
                                <td class="p-4 text-center flex justify-center items-center space-x-4">
                                    
                                    <a asp-action="Details" asp-route-id="@item.CompanyId" class="text-slate-400 hover:text-brand dark:hover:text-brand transition" title="Ver Detalles de Trazabilidad">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>

                                    @if (item.Status == "Active")
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.CompanyId" class="text-slate-400 hover:text-amber-500 transition" title="Editar Configuración">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.CompanyId" method="post" class="inline-block m-0 p-0">
                                            <button type="submit" class="text-slate-400 hover:text-red-500 dark:hover:text-red-400 transition bg-transparent border-none p-0 cursor-pointer" title="Suspender Inquilino" onclick="return confirm('¿Estás seguro de suspender esta empresa?');">
                                                <i class="fa-solid fa-power-off"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-slate-300 dark:text-slate-600 cursor-not-allowed" title="Restaura la empresa para poder editarla">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </span>

                                        <form asp-action="Reactivate" asp-route-id="@item.CompanyId" method="post" class="inline-block m-0 p-0" onsubmit="return confirm('¿Estás seguro de que deseas reactivar esta empresa y a su Administrador (QA Manager)?');">
                                            <button type="submit" class="text-slate-400 hover:text-green-500 transition bg-transparent border-none p-0 cursor-pointer" title="Reactivar Empresa">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        
        <div class="bg-slate-50 dark:bg-[#2a2b2e] px-4 py-3 border-t border-slate-200 dark:border-[#4a4b50] flex items-center justify-between sm:px-6 transition-colors duration-300">
            <div class="text-sm text-slate-500 dark:text-slate-400">
                Mostrando <span class="font-bold text-slate-800 dark:text-white">@Model.Count()</span> empresas registradas
            </div>
        </div>
    </div>
</div>