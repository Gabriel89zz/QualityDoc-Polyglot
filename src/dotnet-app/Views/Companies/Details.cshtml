@model QualityDoc.API.Models.Company

@{
    ViewData["Title"] = "Detalles de la Empresa";
}

<div class="max-w-4xl mx-auto space-y-6 mt-4">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-brand transition-colors">Empresas</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Ficha Técnica</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-brand/5 dark:bg-brand/10 border-b border-brand/10 dark:border-brand/20 p-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div class="flex items-center">
                <div class="bg-brand text-white h-12 w-12 flex items-center justify-center rounded-xl text-xl mr-4 shadow-sm shadow-brand/20">
                    <i class="fa-solid fa-building"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-brand dark:text-brand-light">@Model.LegalName</h2>
                    <p class="text-sm text-slate-600 dark:text-slate-400 font-mono mt-0.5"><i class="fa-solid fa-id-card text-brand/60 mr-1"></i> RFC: @Model.TaxId</p>
                </div>
            </div>
            <div>
                @if (Model.Status == "Active")
                {
                    <span class="bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 px-3 py-1.5 rounded-full text-xs font-bold border border-green-200 dark:border-green-800/30 shadow-sm">
                        <i class="fa-solid fa-circle-check mr-1"></i> Operación Activa
                    </span>
                }
                else
                {
                    <span class="bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 px-3 py-1.5 rounded-full text-xs font-bold border border-red-200 dark:border-red-800/30 shadow-sm">
                        <i class="fa-solid fa-circle-xmark mr-1"></i> Inactiva / Suspendida
                    </span>
                }
            </div>
        </div>

        <div class="p-6 md:p-8">
            <h3 class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-[#4a4b50] pb-2 mb-5">Trazabilidad del Sistema</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <div class="bg-slate-50 dark:bg-[#2a2b2e] p-4 rounded-xl border border-slate-100 dark:border-transparent">
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-bold uppercase tracking-wider mb-1">Registro Inicial</p>
                    <p class="text-sm text-slate-800 dark:text-slate-300">
                        <i class="fa-regular fa-calendar mr-2 text-slate-400"></i> @Model.CreatedAt.ToLocalTime().ToString("dd MMMM, yyyy - HH:mm")
                    </p>
                    <p class="text-sm text-slate-800 dark:text-slate-300 mt-2">
                        <i class="fa-solid fa-user-shield mr-2 text-slate-400"></i> Creado por: <span class="font-semibold text-slate-800 dark:text-white">@(Model.CreatedByNavigation?.FullName ?? "Sistema")</span>
                    </p>
                </div>

                <div class="bg-slate-50 dark:bg-[#2a2b2e] p-4 rounded-xl border border-slate-100 dark:border-transparent">
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-bold uppercase tracking-wider mb-1">Última Modificación</p>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <p class="text-sm text-slate-800 dark:text-slate-300">
                            <i class="fa-regular fa-clock mr-2 text-slate-400"></i> @Model.UpdatedAt.Value.ToLocalTime().ToString("dd MMMM, yyyy - HH:mm")
                        </p>
                        <p class="text-sm text-slate-800 dark:text-slate-300 mt-2">
                            <i class="fa-solid fa-user-pen mr-2 text-slate-400"></i> Modificado por: <span class="font-semibold text-slate-800 dark:text-white">@(Model.UpdatedByNavigation?.FullName ?? "Sistema")</span>
                        </p>
                    }
                    else
                    {
                        <p class="text-sm text-slate-500 dark:text-slate-400 italic mt-2">No registra modificaciones posteriores.</p>
                    }
                </div>

                @if (Model.Status == "Inactive" || Model.Status == "Deleted")
                {
                    <div class="bg-red-50 dark:bg-red-900/20 p-4 rounded-xl border border-red-100 dark:border-transparent md:col-span-2 mt-2">
                        <p class="text-xs text-red-500 dark:text-red-400 font-bold uppercase tracking-wider mb-1">Detalles de Suspensión</p>
                        <p class="text-sm text-red-800 dark:text-red-300">
                            <i class="fa-solid fa-calendar-xmark mr-2 text-red-400"></i> @(Model.DeletedAt?.ToLocalTime().ToString("dd MMMM, yyyy - HH:mm") ?? "Fecha desconocida")
                        </p>
                        <p class="text-sm text-red-800 dark:text-red-300 mt-2">
                            <i class="fa-solid fa-user-slash mr-2 text-red-400"></i> Suspendido por: <span class="font-semibold">@(Model.DeletedByNavigation?.FullName ?? "Sistema")</span>
                        </p>
                    </div>
                }
            </div>
        </div>

        <div class="p-6 md:p-8 border-t border-slate-100 dark:border-[#4a4b50] bg-white dark:bg-[#323338] transition-colors">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-3">
                <h3 class="text-sm font-bold text-slate-800 dark:text-white uppercase tracking-widest">Administradores de la Cuenta (QA Managers)</h3>
                <span class="bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 border border-blue-200 dark:border-blue-800/30 text-xs font-bold px-3 py-1.5 rounded-full">
                    <i class="fa-solid fa-users text-[10px] mr-1"></i> @(Model.Users?.Count() ?? 0) Usuarios
                </span>
            </div>
            
            @if (Model.Users != null && Model.Users.Any())
            {
                <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-[#4a4b50]">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-slate-50 dark:bg-[#2a2b2e] text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
                            <tr>
                                <th class="p-4 font-semibold">Nombre</th>
                                <th class="p-4 font-semibold">Correo</th>
                                <th class="p-4 font-semibold">Rol</th>
                                <th class="p-4 font-semibold text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50] text-sm">
                            @foreach (var user in Model.Users)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition duration-150">
                                    <td class="p-4 font-bold text-slate-800 dark:text-white">
                                        <div class="flex items-center">
                                            <div class="w-8 h-8 rounded-full bg-brand/10 border border-brand/20 text-brand flex items-center justify-center mr-3 font-bold text-xs shadow-sm">
                                                @user.FullName.Substring(0, 1).ToUpper()
                                            </div>
                                            @user.FullName
                                        </div>
                                    </td>
                                    <td class="p-4 text-slate-500 dark:text-slate-400">@user.Email</td>
                                    <td class="p-4">
                                        <span class="bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800/30 text-purple-700 dark:text-purple-400 px-2.5 py-1 rounded-md text-xs font-bold">
                                            <i class="fa-solid fa-user-tie mr-1"></i> @(user.Role?.RoleName ?? "Sin Rol")
                                        </span>
                                    </td>
                                    <td class="p-4 text-center">
                                        @if (user.Status == "Active")
                                        {
                                            <i class="fa-solid fa-circle-check text-green-500" title="Activo"></i>
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-circle-xmark text-red-500" title="Inactivo"></i>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="bg-slate-50 dark:bg-[#2a2b2e] p-8 rounded-xl text-center border border-slate-100 dark:border-transparent">
                    <i class="fa-solid fa-user-shield text-slate-300 dark:text-slate-600 text-4xl mb-3"></i>
                    <p class="text-sm font-bold text-slate-600 dark:text-slate-300">Sin Administrador</p>
                    <p class="text-xs text-slate-500 mt-1">Esta empresa aún no tiene un usuario QA Manager asignado.</p>
                </div>
            }
        </div>

        <div class="bg-slate-50 dark:bg-[#2a2b2e] p-5 border-t border-slate-100 dark:border-[#4a4b50] flex flex-col sm:flex-row justify-between items-center transition-colors duration-300 gap-4">
            <a asp-action="Index" class="text-slate-500 hover:text-slate-800 dark:hover:text-white text-sm font-bold py-2 px-4 transition flex items-center">
                <i class="fa-solid fa-arrow-left mr-2"></i> Volver a la lista
            </a>
            <a asp-action="Edit" asp-route-id="@Model.CompanyId" class="bg-brand/10 hover:bg-brand/20 dark:bg-brand/20 dark:hover:bg-brand/30 text-brand dark:text-brand-light text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150 flex items-center">
                <i class="fa-solid fa-pen-to-square mr-2"></i> Editar Cliente
            </a>
        </div>
    </div>
</div>