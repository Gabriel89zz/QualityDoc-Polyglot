@model QualityDoc.API.Models.Company

@{
    ViewData["Title"] = "Editar Empresa";
}

<div class="max-w-3xl mx-auto space-y-6 mt-4">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-2">
            <li>
                <a asp-action="Index" class="hover:text-brand transition-colors">Empresas</a>
            </li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Modificar Cliente</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-amber-50 dark:bg-amber-900/10 border-b border-amber-100 dark:border-amber-900/20 p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div class="flex items-center">
                <div class="bg-amber-500 text-white h-12 w-12 flex items-center justify-center rounded-xl text-xl mr-4 shadow-sm shadow-amber-500/20">
                    <i class="fa-solid fa-building-circle-check"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-amber-900 dark:text-amber-400">Actualizar Datos Legales</h2>
                    <p class="text-sm text-amber-700 dark:text-amber-500/80">Editando la ficha de: <span class="font-bold">@Model.LegalName</span></p>
                </div>
            </div>
            
            <div class="text-xs text-slate-500 dark:text-slate-400 text-left md:text-right bg-white dark:bg-[#2a2b2e] px-4 py-2 rounded-lg border border-slate-200 dark:border-[#4a4b50] shadow-sm">
                <p class="font-semibold text-slate-700 dark:text-slate-300"><i class="fa-solid fa-fingerprint mr-1 text-brand"></i> ID Sistema: #@Model.CompanyId</p>
                <p class="mt-1"><i class="fa-regular fa-calendar mr-1"></i> Registrada: @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
            </div>
        </div>

        <form asp-action="Edit" class="p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6 font-semibold bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-transparent"></div>
            
            <input type="hidden" asp-for="CompanyId" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-2">
                    <label asp-for="LegalName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nombre Legal / Razón Social</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-building text-slate-400"></i>
                        </div>
                        <input asp-for="LegalName" class="block w-full pl-10 pr-3 py-2.5 rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] text-slate-700 dark:text-white focus:border-amber-500 dark:focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 text-sm transition outline-none" />
                    </div>
                    <span asp-validation-for="LegalName" class="text-red-500 text-xs italic font-semibold mt-1 block"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="TaxId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">RFC / Tax ID</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-id-card text-slate-400"></i>
                        </div>
                        <input asp-for="TaxId" class="block w-full pl-10 pr-3 py-2.5 rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] text-slate-700 dark:text-white focus:border-amber-500 dark:focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 text-sm font-mono font-semibold uppercase transition outline-none" />
                    </div>
                    <span asp-validation-for="TaxId" class="text-red-500 text-xs italic font-semibold mt-1 block"></span>
                </div>

                <div class="space-y-2 md:col-span-2">
                    <label asp-for="Status" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Estado de Operación</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-toggle-on text-slate-400"></i>
                        </div>
                        <select asp-for="Status" class="block w-full pl-10 pr-3 py-2.5 rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] text-slate-700 dark:text-white focus:border-amber-500 dark:focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 text-sm transition appearance-none outline-none font-bold">
                            <option value="Active">Activo (Acceso Permitido al Tenant)</option>
                            <option value="Inactive">Inactivo (Acceso Bloqueado)</option>
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-slate-400 text-[10px]"></i>
                        </div>
                    </div>
                    <span asp-validation-for="Status" class="text-red-500 text-xs italic font-semibold mt-1 block"></span>
                </div>
            </div>

            <div class="flex items-center justify-end space-x-3 pt-8 mt-4 border-t border-slate-100 dark:border-[#4a4b50]">
                <a asp-action="Index" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150">
                    Descartar Cambios
                </a>
                <button type="submit" class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-2.5 px-6 rounded-xl shadow-md shadow-amber-500/20 hover:shadow-lg transition duration-200 flex items-center text-sm">
                    <i class="fa-solid fa-rotate mr-2 text-lg"></i> Actualizar Información
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}