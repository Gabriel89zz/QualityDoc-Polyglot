@model QualityDoc.API.Models.Company

@{
    ViewData["Title"] = "Registrar Nueva Empresa";
}

<div class="max-w-3xl mx-auto space-y-6 mt-4">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-2">
            <li>
                <a asp-action="Index" class="hover:text-brand transition-colors">Empresas</a>
            </li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Nueva Empresa</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-brand/5 dark:bg-brand/10 border-b border-brand/10 dark:border-brand/20 p-6 flex items-center">
            <div class="bg-brand text-white h-12 w-12 flex items-center justify-center rounded-xl text-xl mr-4 shadow-sm shadow-brand/20">
                <i class="fa-solid fa-building-circle-arrow-right"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-brand dark:text-brand-light">Alta de Cliente Corporativo</h2>
                <p class="text-sm text-slate-600 dark:text-slate-400">Registra una nueva entidad legal en el sistema multi-tenant.</p>
            </div>
        </div>

        <form asp-action="Create" class="p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6 font-semibold bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-transparent"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-2">
                    <label asp-for="LegalName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nombre Legal / Razón Social <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-building text-slate-400"></i>
                        </div>
                        <input asp-for="LegalName" 
                               class="block w-full pl-10 pr-3 py-2.5 rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 text-sm transition outline-none" 
                               placeholder="Ej. Merco S.A. de C.V." required />
                    </div>
                    <span asp-validation-for="LegalName" class="text-red-500 text-xs italic font-semibold mt-1 block"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="TaxId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">RFC / Tax ID <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-id-card text-slate-400"></i>
                        </div>
                        <input asp-for="TaxId" 
                               class="block w-full pl-10 pr-3 py-2.5 rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 text-sm font-mono font-semibold uppercase transition outline-none" 
                               placeholder="ABC123456XYZ" required />
                    </div>
                    <span asp-validation-for="TaxId" class="text-red-500 text-xs italic font-semibold mt-1 block"></span>
                </div>
            </div>

            @* <div class="mt-8 bg-brand/5 dark:bg-brand/10 border-l-4 border-brand p-5 rounded-r-xl">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i class="fa-solid fa-circle-info text-brand text-lg"></i>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-sm font-bold text-brand dark:text-brand-light">Información del Sistema</h3>
                        <div class="mt-2 text-sm text-slate-600 dark:text-slate-300 leading-relaxed">
                            <p>Al guardar esta empresa, el sistema generará automáticamente los registros de auditoría necesarios para cumplir con la norma <strong class="text-slate-800 dark:text-white">ISO 9001</strong>. El estado inicial será <strong class="text-slate-800 dark:text-white">Activo</strong>.</p>
                        </div>
                    </div>
                </div>
            </div> *@

            <div class="flex items-center justify-end space-x-3 pt-8 mt-4 border-t border-slate-100 dark:border-[#4a4b50]">
                <a asp-action="Index" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150">
                    Cancelar
                </a>
                <button type="submit" class="bg-brand hover:bg-brand-hover text-white font-bold py-2.5 px-6 rounded-xl shadow-md shadow-brand/20 hover:shadow-lg transition duration-200 flex items-center text-sm">
                    <i class="fa-solid fa-floppy-disk mr-2 text-lg"></i> Guardar Empresa
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}