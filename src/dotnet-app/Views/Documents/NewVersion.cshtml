@model QualityDoc.API.Models.NewDocumentVersionViewModel

@{
    ViewData["Title"] = "Subir Nueva Versión";
}

<div class="max-w-4xl mx-auto space-y-6 mt-4">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-brand transition-colors">Documentos</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li><a asp-action="Details" asp-route-id="@Model.DocId" class="hover:text-brand transition-colors">Expediente</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Nueva Versión</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-brand/5 dark:bg-brand/10 border-b border-brand/10 dark:border-brand/20 p-6 flex items-center">
            <div class="bg-brand text-white h-12 w-12 flex items-center justify-center rounded-xl text-xl mr-4 shadow-sm shadow-brand/20">
                <i class="fa-solid fa-cloud-arrow-up"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-brand dark:text-brand-light">Subir Nueva Versión</h2>
                <p class="text-sm text-slate-600 dark:text-slate-400">Actualiza el archivo PDF y documenta el motivo del cambio.</p>
            </div>
        </div>

        <div class="p-6 md:p-8">
            <form asp-action="NewVersion" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-red-500 mb-6 text-sm font-semibold bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-transparent"></div>

                <input type="hidden" asp-for="DocId" />

                <div class="bg-slate-50 dark:bg-[#2a2b2e] border border-slate-200 dark:border-[#4a4b50] rounded-xl p-5 mb-8 flex items-center shadow-sm transition-colors">
                    <div class="w-12 h-12 bg-white dark:bg-[#323338] rounded-full flex items-center justify-center border border-slate-200 dark:border-[#4a4b50] mr-4 shadow-sm">
                        <i class="fa-solid fa-file-circle-check text-2xl text-brand/60"></i>
                    </div>
                    <div>
                        <p class="text-xs text-slate-400 dark:text-slate-500 font-bold uppercase tracking-wider mb-1">Actualizando Documento</p>
                        <p class="text-lg font-black text-slate-800 dark:text-white">@Model.DocCode <span class="font-medium text-slate-500 dark:text-slate-400 ml-1">- @Model.DocName</span></p>
                    </div>
                </div>

                <div class="grid grid-cols-1 gap-8">
                    
                    <div>
                        <label asp-for="ChangeDescription" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">
                            Motivo del Cambio (Justificación) <span class="text-red-500">*</span>
                        </label>
                        <textarea asp-for="ChangeDescription" rows="3" class="w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-3 text-slate-700 dark:text-white placeholder-slate-400 focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none resize-none" placeholder="Ej. Se actualizó el diagrama de flujo debido a la compra de la nueva máquina CNC..." required></textarea>
                        <span asp-validation-for="ChangeDescription" class="text-red-500 text-xs mt-1 block font-semibold"></span>
                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 font-medium">
                            <i class="fa-solid fa-circle-info mr-1 text-brand/70"></i> Este campo es auditable por ISO 9001 y se guardará permanentemente en la bitácora.
                        </p>
                    </div>

                    <div>
                        <label asp-for="NewFile" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">
                            Nuevo Archivo (PDF/Word) <span class="text-red-500">*</span>
                        </label>
                        
                        <div class="bg-slate-50 dark:bg-[#2a2b2e] border-2 border-dashed border-slate-300 dark:border-[#4a4b50] rounded-2xl p-8 text-center hover:bg-slate-100 dark:hover:bg-[#323338] transition duration-150 ease-in-out">
                            <div class="w-16 h-16 bg-white dark:bg-[#323338] rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm border border-slate-100 dark:border-transparent">
                                <i class="fa-solid fa-file-arrow-up text-2xl text-brand/60"></i>
                            </div>
                            
                            <input type="file" name="NewFile" id="NewFile" class="block w-full text-sm text-slate-500 dark:text-slate-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-bold file:bg-brand/10 file:text-brand dark:file:bg-brand/20 dark:file:text-brand-light hover:file:bg-brand/20 cursor-pointer transition mt-4 mx-auto" accept=".pdf,.doc,.docx,.xls,.xlsx" required />
                            
                            <p class="text-xs text-slate-400 dark:text-slate-500 mt-4 font-medium">Tamaño máximo recomendado: 10MB.</p>
                            
                            @if (ViewData.ModelState["NewFile"]?.Errors.Count > 0)
                            {
                                <span class="text-red-500 text-sm font-bold block mt-3">@ViewData.ModelState["NewFile"]?.Errors[0].ErrorMessage</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="mt-10 pt-6 border-t border-slate-100 dark:border-[#4a4b50] flex justify-end space-x-3 transition-colors duration-300">
                    <a asp-action="Details" asp-route-id="@Model.DocId" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150">
                        Cancelar
                    </a>
                    <button type="submit" class="bg-brand hover:bg-brand-hover text-white text-sm font-bold py-2.5 px-6 rounded-xl shadow-md shadow-brand/20 flex items-center transition duration-150">
                        <i class="fa-solid fa-cloud-arrow-up mr-2 text-lg"></i> Guardar Nueva Versión
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}