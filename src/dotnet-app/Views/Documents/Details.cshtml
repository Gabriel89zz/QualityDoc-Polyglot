@model QualityDoc.API.Models.Document
@using QualityDoc.API.Models

@{
    ViewData["Title"] = "Expediente del Documento";
    var versiones = ViewBag.Versions as IEnumerable<DocumentVersion>;
    
    var creators = ViewBag.Creators as Dictionary<int, string>;
    
    // 🧠 Lógica de Permisos Visuales
    bool isAdmin = User.IsInRole("Admin de Empresa");
    bool isCreator = User.IsInRole("Creador de Doc");
    int myDeptId = ViewBag.UserDeptId ?? 0;

    bool hasPowerOverDoc = isAdmin || (isCreator && Model.DeptId == myDeptId);

    var lastVersion = versiones?.FirstOrDefault();
    
    bool isDraft = lastVersion != null && lastVersion.StatusId == 1;
    bool canUploadNewVersion = lastVersion != null && (lastVersion.StatusId == 3 || lastVersion.StatusId == 4);
}

<div class="max-w-7xl mx-auto mt-6">
    
    <!-- 🚀 ALERTAS DEL SISTEMA -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-6 rounded shadow-sm">
            <div class="flex items-center">
                <i class="fa-solid fa-circle-check text-green-500 text-xl mr-3"></i>
                <p class="text-sm font-bold text-green-800">@TempData["SuccessMessage"]</p>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded shadow-sm">
            <div class="flex items-center">
                <i class="fa-solid fa-triangle-exclamation text-red-500 text-xl mr-3"></i>
                <p class="text-sm font-bold text-red-800">@TempData["ErrorMessage"]</p>
            </div>
        </div>
    }

    <!-- HEADER: Título y Botones Administrativos -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6">
        <div>
            <div class="flex items-center space-x-3">
                <h2 class="text-3xl font-black text-gray-800 tracking-tight">
                    @Model.DocCode
                </h2>
                @if (Model.Status == "Active")
                {
                    <span class="px-3 py-1 bg-green-100 text-green-800 text-xs font-bold rounded-full border border-green-200">Activo</span>
                }
                else
                {
                    <span class="px-3 py-1 bg-red-100 text-red-800 text-xs font-bold rounded-full border border-red-200">Suspendido</span>
                }
            </div>
            <p class="text-gray-600 font-medium text-lg mt-1">@Model.DocName</p>
        </div>
        
        <div class="mt-4 sm:mt-0 flex flex-wrap gap-2">
            <a asp-action="Index" class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-100 font-medium py-2 px-4 rounded shadow-sm transition inline-flex items-center text-sm">
                <i class="fa-solid fa-arrow-left mr-2"></i> Volver
            </a>
            
            @if (hasPowerOverDoc && isDraft)
            {
                <a asp-action="Edit" asp-route-id="@Model.DocId" class="bg-gray-800 hover:bg-gray-900 text-white font-medium py-2 px-4 rounded shadow-sm transition inline-flex items-center text-sm">
                    <i class="fa-solid fa-pen mr-2"></i> Editar Documento
                </a>
            }
        </div>
    </div>

    <!-- SECCIÓN 1: METADATOS (Información General) -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 mb-6">
        <div class="p-6">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4 border-b pb-2">Información del Documento</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-y-6 gap-x-8">
                <div>
                    <p class="text-sm text-gray-500 font-medium">Categoría</p>
                    <p class="mt-1 text-base text-gray-900 font-semibold"><i class="fa-solid fa-folder-tree text-blue-500 mr-2"></i>@Model.Category?.CategoryName</p>
                </div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">Departamento Propietario</p>
                    <p class="mt-1 text-base text-gray-900 font-semibold"><i class="fa-solid fa-building-user text-indigo-500 mr-2"></i>@Model.Department?.DeptName</p>
                </div>
                <div>
                    <p class="text-sm text-gray-500 font-medium">Origen del Documento</p>
                    <p class="mt-1">
                        @if (Model.IsExternal)
                        {
                            <span class="inline-flex items-center text-sm font-semibold text-purple-700"><i class="fa-solid fa-cloud-arrow-down mr-2"></i> Externo</span>
                        }
                        else
                        {
                            <span class="inline-flex items-center text-sm font-semibold text-teal-700"><i class="fa-solid fa-house-laptop mr-2"></i> Interno</span>
                        }
                    </p>
                </div>
                <div class="md:col-span-3">
                    <p class="text-sm text-gray-500 font-medium mb-2">Descripción / Objetivo</p>
                    <div class="bg-gray-50 border-l-4 border-gray-400 p-4 rounded text-gray-700 text-sm">
                        @(string.IsNullOrEmpty(Model.Description) ? "No se ha proporcionado un objetivo para este documento." : Model.Description)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SECCIÓN 2: HISTORIAL DE VERSIONES -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 mb-6">
        <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center bg-gray-50">
            <h3 class="text-xs font-bold text-gray-700 uppercase tracking-widest"><i class="fa-solid fa-clock-rotate-left mr-2"></i> Archivos y Versiones</h3>
            
            @if (hasPowerOverDoc && canUploadNewVersion)
            {
                <a asp-action="NewVersion" asp-route-id="@Model.DocId" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 px-4 rounded shadow-sm transition">
                    <i class="fa-solid fa-cloud-arrow-up mr-2"></i> Subir Nueva Versión
                </a>
            }
        </div>
        
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-white">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Versión</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Estatus</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Motivo del Cambio</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Fecha</th>
                        <th class="px-6 py-3 text-right text-xs font-bold text-gray-500 uppercase">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white">
                    @if (versiones != null && versiones.Any())
                    {
                        foreach (var version in versiones)
                        {
                            bool isLatest = version.VersionId == lastVersion?.VersionId;
                            string rowClass = isLatest ? "bg-indigo-50 bg-opacity-50" : "hover:bg-gray-50";

                            <tr id="row-@version.VersionId" class="transition-colors version-row @rowClass">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-black text-gray-900">
                                    v @version.VersionNum
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    @if (version.StatusId == 1)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-gray-100 text-gray-600 border border-gray-200">
                                            <i class="fa-solid fa-pen-ruler mr-1.5"></i> Borrador
                                        </span>
                                    }
                                    else if (version.StatusId == 2)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-blue-50 text-blue-700 border border-blue-200">
                                            <i class="fa-solid fa-spinner fa-spin mr-1.5"></i> En Revisión
                                        </span>
                                    }
                                    else if (version.StatusId == 3)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-green-50 text-green-700 border border-green-200">
                                            <i class="fa-solid fa-check-double mr-1.5"></i> Aprobado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-yellow-50 text-yellow-700 border border-yellow-200">
                                            Obsoleto
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 max-w-md truncate" title="@version.ChangeDescription">
                                    @version.ChangeDescription
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @version.CreatedAt.ToString("dd/MMM/yyyy")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2 flex justify-end">
                                    
                                    <button type="button" onclick="showComments(@version.VersionId)" class="text-indigo-600 hover:text-indigo-900 bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded transition" title="Ver comentarios de esta versión">
                                        <i class="fa-solid fa-comments"></i>
                                    </button>

                                    <a href="@version.FilePath" target="_blank" class="text-blue-600 hover:text-blue-900 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded transition" title="Ver PDF">
                                        <i class="fa-solid fa-file-pdf"></i>
                                    </a>

                                    @if (version.StatusId == 1 && hasPowerOverDoc)
                                    {
                                        <!-- 🚀 NUEVO FORMULARIO: Reemplazar Archivo (Oculto) -->
                                        <form asp-action="ReplaceDraftFile" method="post" enctype="multipart/form-data" class="inline" id="form-replace-@version.VersionId">
                                            <input type="hidden" name="versionId" value="@version.VersionId" />
                                            <input type="hidden" name="docId" value="@Model.DocId" />
                                            <input type="file" name="newFile" id="file-@version.VersionId" accept=".pdf" class="hidden" onchange="if(confirm('¿Estás seguro de que deseas sobreescribir el borrador actual con este nuevo archivo PDF?')) { document.getElementById('form-replace-@version.VersionId').submit(); } else { this.value = ''; }" />
                                            
                                            <button type="button" onclick="document.getElementById('file-@version.VersionId').click();" class="text-orange-600 hover:text-orange-900 bg-orange-50 hover:bg-orange-100 px-3 py-1.5 rounded transition" title="Corregir y reemplazar archivo PDF">
                                                <i class="fa-solid fa-file-arrow-up"></i>
                                            </button>
                                        </form>

                                        <form asp-action="SendToReview" method="post" class="inline ml-2" onsubmit="return confirm('¿Iniciar el flujo de revisión para esta versión?');">
                                            <input type="hidden" name="versionId" value="@version.VersionId" />
                                            <input type="hidden" name="docId" value="@Model.DocId" />
                                            <button type="submit" class="text-green-600 hover:text-green-900 bg-green-50 hover:bg-green-100 px-3 py-1.5 rounded transition" title="Solicitar Firmas">
                                                <i class="fa-solid fa-paper-plane"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-10 text-center text-gray-400">
                                <i class="fa-solid fa-folder-open text-3xl mb-3"></i>
                                <p>Este documento no tiene ninguna versión subida todavía.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- 🚀 SECCIÓN INTERACTIVA: BITÁCORA DE REVISIONES Y COMENTARIOS -->
    <div id="seccion-bitacora" class="bg-white shadow-sm rounded-lg border border-gray-200 mb-6">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
            <h3 class="text-xs font-bold text-gray-700 uppercase tracking-widest"><i class="fa-solid fa-comments mr-2"></i> Bitácora de Aprobaciones</h3>
            <span class="text-xs text-gray-500 bg-white px-2 py-1 rounded border border-gray-200">Selecciona una versión arriba para ver sus detalles</span>
        </div>
        <div class="p-6">
            @if (versiones != null && versiones.Any())
            {
                <div class="space-y-6 relative">
                    @foreach (var version in versiones)
                    {
                        // 🚀 Solo mostramos el bloque si es la última versión
                        bool isLatest = version.VersionId == lastVersion?.VersionId;
                        string displayClass = isLatest ? "block" : "hidden";

                        <div id="comments-@version.VersionId" class="comments-section @displayClass">
                            <div class="border-l-2 border-indigo-200 pl-4 ml-2">
                                <h4 class="text-sm font-bold text-indigo-800 mb-3 bg-indigo-50 inline-block px-3 py-1 rounded-full border border-indigo-100">Mostrando historial de la Versión @version.VersionNum</h4>
                                
                                <div class="space-y-4 mt-2">
                                    <!-- 1. COMENTARIO DEL CREADOR -->
                                    @{
                                        int creatorId = (int?)version.CreatedBy ?? 0;
                                        string creatorName = creators != null && creators.ContainsKey(creatorId) ? creators[creatorId] : "Autor Desconocido";
                                    }
                                    <div class="bg-blue-50 p-4 rounded-lg border border-blue-100 flex flex-col sm:flex-row sm:items-start gap-4 shadow-sm">
                                        <div class="flex-shrink-0 mt-1">
                                            <i class="fa-solid fa-user-pen text-blue-500 text-2xl"></i>
                                        </div>
                                        <div class="flex-grow">
                                            <div class="flex justify-between items-start mb-1">
                                                <div>
                                                    <span class="font-bold text-gray-900 text-sm">@creatorName</span>
                                                    <span class="text-xs text-blue-600 ml-2 font-semibold bg-blue-100 px-2 py-0.5 rounded">Creador</span>
                                                </div>
                                                <span class="text-xs text-gray-400"><i class="fa-regular fa-calendar mr-1"></i> @version.CreatedAt.ToString("dd/MMM/yyyy HH:mm")</span>
                                            </div>
                                            <p class="text-sm font-semibold text-blue-700 mb-2">Acción: Subió el archivo y solicitó revisión</p>
                                            
                                            <div class="bg-white p-3 rounded border border-blue-200 text-sm text-gray-700 relative">
                                                <i class="fa-solid fa-quote-left text-blue-100 absolute top-2 left-2 text-lg"></i>
                                                <p class="pl-6 relative z-10 italic font-medium">
                                                    @(string.IsNullOrEmpty(version.ChangeDescription) ? "Sin descripción detallada." : version.ChangeDescription)
                                                </p>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 2. COMENTARIOS DE LOS REVISORES / APROBADORES -->
                                    @if (version.Approvals != null && version.Approvals.Any(a => a.ApprovalStatus != "Pending"))
                                    {
                                        foreach (var approval in version.Approvals.Where(a => a.ApprovalStatus != "Pending").OrderBy(a => a.UpdatedAt ?? a.CreatedAt))
                                        {
                                            string statusColor = approval.ApprovalStatus == "Approved" ? "text-green-600" : "text-red-600";
                                            string bgCard = approval.ApprovalStatus == "Approved" ? "bg-green-50" : "bg-red-50";
                                            string borderColor = approval.ApprovalStatus == "Approved" ? "border-green-100" : "border-red-100";
                                            string statusIcon = approval.ApprovalStatus == "Approved" ? "fa-circle-check" : "fa-circle-xmark";
                                            string statusText = approval.ApprovalStatus == "Approved" ? "Aprobó" : "Rechazó";

                                            <div class="@bgCard p-4 rounded-lg border @borderColor flex flex-col sm:flex-row sm:items-start gap-4 shadow-sm">
                                                <div class="flex-shrink-0 mt-1">
                                                    <i class="fa-solid @statusIcon @statusColor text-2xl"></i>
                                                </div>
                                                <div class="flex-grow">
                                                    <div class="flex justify-between items-start mb-1">
                                                        <div>
                                                            <span class="font-bold text-gray-900 text-sm">@approval.Approver?.FullName</span>
                                                            <span class="text-xs text-gray-500 ml-2 font-semibold bg-white border @borderColor px-2 py-0.5 rounded">Paso @approval.StepOrder: @approval.StepType</span>
                                                        </div>
                                                        <span class="text-xs text-gray-400"><i class="fa-regular fa-calendar mr-1"></i> @(approval.UpdatedAt?.ToString("dd/MMM/yyyy HH:mm") ?? approval.CreatedAt.ToString("dd/MMM/yyyy HH:mm"))</span>
                                                    </div>
                                                    <p class="text-sm font-semibold @statusColor mb-2">Dictamen: @statusText el documento</p>
                                                    
                                                    <div class="bg-white p-3 rounded border @borderColor text-sm text-gray-700 relative">
                                                        <i class="fa-solid fa-quote-left text-gray-200 absolute top-2 left-2 text-lg"></i>
                                                        <p class="pl-6 relative z-10 italic">
                                                            @(string.IsNullOrEmpty(approval.Comments) ? "Sin comentarios adicionales." : approval.Comments)
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8 text-gray-400">
                    <i class="fa-regular fa-comments text-4xl mb-3"></i>
                    <p class="text-sm">Aún no hay historial para este documento.</p>
                </div>
            }
        </div>
    </div>

    <!-- SECCIÓN 3: AUDITORÍA DE SISTEMA -->
    <div class="bg-gray-50 rounded-lg p-4 text-xs text-gray-500 border border-gray-200 flex flex-col sm:flex-row justify-between items-center">
        <div class="flex items-center space-x-4">
            <span><i class="fa-solid fa-calendar-plus mr-1"></i> Creado: @Model.CreatedAt.ToString("dd/MMM/yyyy HH:mm")</span>
            @if(Model.UpdatedAt.HasValue)
            {
                <span><i class="fa-solid fa-pen mr-1"></i> Modificado: @Model.UpdatedAt.Value.ToString("dd/MMM/yyyy HH:mm")</span>
            }
        </div>
        <div class="mt-2 sm:mt-0">
            <i class="fa-solid fa-fingerprint mr-1"></i> ID Registro: #@Model.DocId
        </div>
    </div>

</div>

<!-- 🚀 SCRIPT PARA CONTROLAR LA INTERACTIVIDAD -->
@section Scripts {
    <script>
        function showComments(versionId) {
            // 1. Ocultar todos los bloques de comentarios
            var blocks = document.querySelectorAll('.comments-section');
            blocks.forEach(function(block) {
                block.classList.remove('block');
                block.classList.add('hidden');
            });

            // 2. Mostrar únicamente el bloque de la versión seleccionada
            var targetBlock = document.getElementById('comments-' + versionId);
            if (targetBlock) {
                targetBlock.classList.remove('hidden');
                targetBlock.classList.add('block');
            }

            // 3. Quitar el sombreado de todas las filas en la tabla
            var rows = document.querySelectorAll('.version-row');
            rows.forEach(function(row) {
                row.classList.remove('bg-indigo-50', 'bg-opacity-50');
                row.classList.add('hover:bg-gray-50');
            });

            // 4. Sombrear la fila que se acaba de seleccionar
            var targetRow = document.getElementById('row-' + versionId);
            if (targetRow) {
                targetRow.classList.remove('hover:bg-gray-50');
                targetRow.classList.add('bg-indigo-50', 'bg-opacity-50');
            }
            
            // 5. UX Premium: Hacer un scroll suave hacia abajo para leer los comentarios
            document.getElementById('seccion-bitacora').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    </script>
}