@model IEnumerable<QualityDoc.API.Models.Document>

@{
    ViewData["Title"] = "Catálogo de Documentos";
    
    // 🧠 Lógica de Permisos Visuales
    bool isAdmin = User.IsInRole("Admin de Empresa");
    bool isCreator = User.IsInRole("Creador de Doc");
    int myDeptId = ViewBag.UserDeptId ?? 0;
    
    // 🧠 Diccionarios de trazabilidad (Enviados desde el Backend)
    var latestStatuses = ViewBag.LatestStatuses as Dictionary<int, int>;
    var hasAdvancedVersions = ViewBag.HasAdvancedVersions as List<int>;
}

<div class="max-w-7xl mx-auto mt-4">
    <!-- Encabezado y Botón -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-800 flex items-center">
                <i class="fa-solid fa-folder-open text-blue-600 mr-3"></i> Documentos Maestros
            </h2>
            <p class="text-gray-500 text-sm mt-1">Gestión y control de la información documentada (ISO 9001)</p>
        </div>
        <div class="mt-4 sm:mt-0">
            @if (isAdmin || isCreator)
            {
                <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md shadow-sm transition inline-flex items-center">
                    <i class="fa-solid fa-plus mr-2"></i> Nuevo Documento
                </a>
            }
        </div>
    </div>

    <!-- Mensaje de Error (En caso de que traten de violar la regla ISO) -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4" role="alert">
            <span class="block sm:inline">
                <i class="fa-solid fa-triangle-exclamation mr-1"></i> @TempData["ErrorMessage"]
            </span>
        </div>
    }

    <!-- Tabla -->
    <div class="bg-white shadow-md rounded-lg overflow-hidden border border-gray-200">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Folio</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Título del Documento</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Categoría</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Departamento</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Origen</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Estatus</th>
                        <th scope="col" class="px-6 py-3 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                                <i class="fa-regular fa-folder-open text-5xl mb-4 text-gray-300"></i>
                                <h5 class="text-lg font-medium text-gray-900 mb-1">No hay documentos registrados</h5>
                                <p class="text-sm">Comienza a organizar tu control documental.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            // 🧠 BLINDAJE: Analizando si es seguro editar/borrar este renglón
                            int latestStatus = latestStatuses != null && latestStatuses.ContainsKey(item.DocId) ? latestStatuses[item.DocId] : 1;
                            bool canEdit = latestStatus == 1; // Solo se edita si está en Borrador
                            bool canDelete = hasAdvancedVersions != null && !hasAdvancedVersions.Contains(item.DocId); // Solo se borra si NUNCA ha avanzado

                            // 🧠 VISUALES: Evaluando qué botones pintar
                            bool showPen = (isAdmin || (isCreator && item.DeptId == myDeptId)) && canEdit;
                            bool showTrash = isAdmin && canDelete && item.Status == "Active";
                            bool showReactivate = isAdmin && item.Status != "Active";
                            
                            bool hasMoreButtons = showPen || showTrash || showReactivate;
                            string eyeRadiusClass = hasMoreButtons ? "rounded-l-md" : "rounded-md";

                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-blue-600">
                                    @item.DocCode
                                </td>
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                    @item.DocName
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <span class="ml-1 text-gray-400 cursor-help" title="@item.Description">
                                            <i class="fa-solid fa-circle-info"></i>
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded border border-gray-300 bg-gray-100 text-gray-800 text-xs font-medium">
                                        @item.Category?.CategoryName
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
                                    @item.Department?.DeptName
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    @if (item.IsExternal)
                                    {
                                        <span class="inline-flex items-center text-xs font-medium text-purple-700 bg-purple-100 rounded-full px-2 py-1">
                                            <i class="fa-solid fa-arrow-right-to-bracket mr-1"></i> Externo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center text-xs font-medium text-teal-700 bg-teal-100 rounded-full px-2 py-1">
                                            <i class="fa-solid fa-building-user mr-1"></i> Interno
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                                            <i class="fa-solid fa-circle-check mr-1"></i> Vigente
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 border border-red-200">
                                            <i class="fa-solid fa-circle-xmark mr-1"></i> Suspendido
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                                    <div class="inline-flex shadow-sm rounded-md" role="group">
                                        
                                        <!-- OJO: Lo ven todos -->
                                        <a asp-action="Details" asp-route-id="@item.DocId" class="inline-flex items-center px-3 py-1.5 border border-gray-300 bg-white text-blue-600 hover:bg-gray-50 @eyeRadiusClass hover:text-blue-700 transition" title="Ver Detalles">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        
                                        <!-- 🔒 LÁPIZ: Reglas ISO Estrictas -->
                                        @if (showPen)
                                        {
                                            bool isLast = !showTrash && !showReactivate;
                                            string penBorderClass = isLast ? "border border-l-0 border-gray-300 rounded-r-md" : "border-t border-b border-gray-300";

                                            <a asp-action="Edit" asp-route-id="@item.DocId" class="inline-flex items-center px-3 py-1.5 bg-white text-yellow-500 hover:bg-gray-50 hover:text-yellow-600 transition @penBorderClass" title="Editar Documento">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                        }

                                        <!-- 🔒 BASURERO / REACTIVAR: Reglas ISO Estrictas -->
                                        @if (showTrash)
                                        {
                                            <form asp-action="Delete" asp-route-id="@item.DocId" method="post" class="inline-block m-0" onsubmit="return confirm('¿Estás seguro de suspender este documento? Pasará a estado inactivo.');">
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-l-0 border-gray-300 bg-white text-red-500 hover:bg-gray-50 rounded-r-md hover:text-red-700 transition" title="Suspender (Solo permitido en fase de Borrador)">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        }
                                        
                                        @if (showReactivate)
                                        {
                                            <form asp-action="Reactivate" asp-route-id="@item.DocId" method="post" class="inline-block m-0" onsubmit="return confirm('¿Deseas reactivar este documento al sistema?');">
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-l-0 border-gray-300 bg-white text-green-500 hover:bg-gray-50 rounded-r-md hover:text-green-700 transition" title="Reactivar">
                                                    <i class="fa-solid fa-rotate-left"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>