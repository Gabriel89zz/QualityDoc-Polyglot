@model IEnumerable<QualityDoc.API.Models.Document>

@{
    ViewData["Title"] = "Catálogo de Documentos";
    
    // 🧠 Lógica de Permisos Visuales
    bool isAdmin = User.IsInRole("Admin de Empresa");
    bool isCreator = User.IsInRole("Creador de Doc");
    int myDeptId = ViewBag.UserDeptId ?? 0;
    
    // 🧠 Diccionarios de trazabilidad (Enviados desde el Backend)
    var latestStatuses = ViewBag.LatestStatuses as Dictionary<int, int>;
    var hasAdvancedVersions = ViewBag.HasAdvancedVersions as List<int>;
}

<div class="max-w-7xl mx-auto space-y-6">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white dark:bg-[#323338] p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] transition-colors duration-300">
        <div>
            <h2 class="text-2xl font-bold text-slate-800 dark:text-white flex items-center">
                <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mr-3 border border-brand/20">
                    <i class="fa-solid fa-folder-open text-brand"></i>
                </div>
                Documentos Maestros
            </h2>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Gestión y control de la información documentada (ISO 9001)</p>
        </div>
        <div class="mt-4 sm:mt-0">
            @if (isAdmin || isCreator)
            {
                <a asp-action="Create" class="bg-brand hover:bg-brand-hover text-white font-bold py-2.5 px-5 rounded-xl shadow-md shadow-brand/20 flex items-center transition duration-200">
                    <i class="fa-solid fa-plus mr-2"></i> Nuevo Documento
                </a>
            }
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 rounded-r-xl shadow-sm border border-y-red-100 border-r-red-100 dark:border-transparent transition-colors duration-300">
            <span class="block sm:inline text-red-700 dark:text-red-400 text-sm font-bold">
                <i class="fa-solid fa-triangle-exclamation mr-1"></i> @TempData["ErrorMessage"]
            </span>
        </div>
    }

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        <div class="overflow-x-auto">
            <table class="min-w-full text-left border-collapse">
                <thead class="bg-slate-50 dark:bg-[#2a2b2e] text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider transition-colors duration-300">
                    <tr>
                        <th scope="col" class="p-4 font-semibold">Folio</th>
                        <th scope="col" class="p-4 font-semibold">Título del Documento</th>
                        <th scope="col" class="p-4 font-semibold">Categoría</th>
                        <th scope="col" class="p-4 font-semibold">Departamento</th>
                        <th scope="col" class="p-4 font-semibold">Origen</th>
                        <th scope="col" class="p-4 font-semibold">Estatus</th>
                        <th scope="col" class="p-4 font-semibold text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50] text-sm">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="p-10 text-center text-slate-500 dark:text-slate-400">
                                <i class="fa-regular fa-folder-open text-4xl mb-3 text-slate-300 dark:text-slate-600 block"></i>
                                <h5 class="text-lg font-bold text-slate-700 dark:text-slate-300 mb-1">No hay documentos registrados</h5>
                                <p class="text-sm">Comienza a organizar tu control documental.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            // 🧠 BLINDAJE: Analizando si es seguro editar/borrar este renglón
                            int latestStatus = latestStatuses != null && latestStatuses.ContainsKey(item.DocId) ? latestStatuses[item.DocId] : 1;
                            bool canEdit = latestStatus == 1; // Solo se edita si está en Borrador
                            bool canDelete = hasAdvancedVersions != null && !hasAdvancedVersions.Contains(item.DocId); // Solo se borra si NUNCA ha avanzado

                            // 🧠 VISUALES: Evaluando qué botones pintar
                            bool showPen = (isAdmin || (isCreator && item.DeptId == myDeptId)) && canEdit;
                            bool showTrash = isAdmin && canDelete && item.Status == "Active";
                            bool showReactivate = isAdmin && item.Status != "Active";

                            bool hasMoreButtons = showPen || showTrash || showReactivate;
                            string eyeRadiusClass = hasMoreButtons ? "rounded-l-lg" : "rounded-lg";

                            <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition duration-150">
                                <td class="p-4 whitespace-nowrap text-sm font-bold text-brand dark:text-brand-light">
                                    @item.DocCode
                                </td>
                                <td class="p-4 text-sm font-bold text-slate-800 dark:text-white">
                                    @item.DocName
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <span class="ml-1 text-slate-400 dark:text-slate-500 cursor-help" title="@item.Description">
                                            <i class="fa-solid fa-circle-info"></i>
                                        </span>
                                    }
                                </td>
                                <td class="p-4 whitespace-nowrap text-sm">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md border border-slate-200 dark:border-[#4a4b50] bg-slate-50 dark:bg-[#2a2b2e] text-slate-700 dark:text-slate-300 text-xs font-semibold shadow-sm">
                                        @item.Category?.CategoryName
                                    </span>
                                </td>
                                <td class="p-4 whitespace-nowrap text-sm text-slate-700 dark:text-slate-300 font-medium">
                                    @item.Department?.DeptName
                                </td>
                                <td class="p-4 whitespace-nowrap text-sm">
                                    @if (item.IsExternal)
                                    {
                                        <span class="inline-flex items-center text-xs font-bold text-purple-700 dark:text-purple-400 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800/30 rounded-full px-2.5 py-1">
                                            <i class="fa-solid fa-arrow-right-to-bracket mr-1"></i> Externo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center text-xs font-bold text-teal-700 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/20 border border-teal-200 dark:border-teal-800/30 rounded-full px-2.5 py-1">
                                            <i class="fa-solid fa-building-user mr-1"></i> Interno
                                        </span>
                                    }
                                </td>
                                <td class="p-4 whitespace-nowrap text-sm">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800/30">
                                            <i class="fa-solid fa-circle-check mr-1"></i> Vigente
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-800/30">
                                            <i class="fa-solid fa-circle-xmark mr-1"></i> Suspendido
                                        </span>
                                    }
                                </td>
                                <td class="p-4 whitespace-nowrap text-center text-sm font-medium">
                                    
                                    <div class="inline-flex shadow-sm rounded-lg" role="group">
                                        
                                        <a asp-action="Details" asp-route-id="@item.DocId" class="inline-flex items-center px-3 py-1.5 border border-slate-200 dark:border-[#4a4b50] bg-white dark:bg-[#2a2b2e] text-slate-400 hover:bg-slate-50 dark:hover:bg-[#323338] @eyeRadiusClass hover:text-brand dark:hover:text-brand-light transition-colors" title="Ver Detalles">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        
                                        @if (showPen)
                                        {
                                            bool isLast = !showTrash && !showReactivate;
                                            string penBorderClass = isLast ? "border border-l-0 border-slate-200 dark:border-[#4a4b50] rounded-r-lg" : "border-t border-b border-slate-200 dark:border-[#4a4b50]";
                                            
                                            <a asp-action="Edit" asp-route-id="@item.DocId" class="inline-flex items-center px-3 py-1.5 bg-white dark:bg-[#2a2b2e] text-slate-400 hover:bg-slate-50 dark:hover:bg-[#323338] hover:text-amber-500 transition-colors @penBorderClass" title="Editar Documento">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                        }

                                        @if (showTrash)
                                        {
                                            <form asp-action="Delete" asp-route-id="@item.DocId" method="post" class="inline-block m-0" onsubmit="return confirm('¿Estás seguro de suspender este documento? Pasará a estado inactivo.');">
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-l-0 border-slate-200 dark:border-[#4a4b50] bg-white dark:bg-[#2a2b2e] text-slate-400 hover:bg-slate-50 dark:hover:bg-[#323338] rounded-r-lg hover:text-red-500 transition-colors" title="Suspender (Solo permitido en fase de Borrador)">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        }
                                        
                                        @if (showReactivate)
                                        {
                                            <form asp-action="Reactivate" asp-route-id="@item.DocId" method="post" class="inline-block m-0" onsubmit="return confirm('¿Deseas reactivar este documento al sistema?');">
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-l-0 border-slate-200 dark:border-[#4a4b50] bg-white dark:bg-[#2a2b2e] text-slate-400 hover:bg-slate-50 dark:hover:bg-[#323338] rounded-r-lg hover:text-green-500 transition-colors" title="Reactivar">
                                                    <i class="fa-solid fa-rotate-left"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        
        <div class="bg-slate-50 dark:bg-[#2a2b2e] px-4 py-3 border-t border-slate-200 dark:border-[#4a4b50] flex items-center justify-between sm:px-6 transition-colors duration-300">
            <div class="text-sm text-slate-500 dark:text-slate-400">
                Mostrando <span class="font-bold text-slate-800 dark:text-white">@Model.Count()</span> documentos
            </div>
        </div>
    </div>
</div>