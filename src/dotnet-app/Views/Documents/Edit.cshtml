@model QualityDoc.API.Models.Document

@{
    ViewData["Title"] = "Editar Documento";
}

<div class="max-w-6xl mx-auto mt-6">
    <div class="bg-white shadow-md rounded-lg overflow-hidden border border-gray-200">
        
        <!-- Header (Mantenemos el color amarillo para indicar que es modo edición) -->
        <div class="bg-yellow-500 px-6 py-4">
            <h4 class="text-white text-lg font-semibold flex items-center">
                <i class="fa-solid fa-pen-to-square mr-2"></i> Editar Documento: @Model.DocCode
            </h4>
        </div>
        
        <div class="p-6 md:p-8">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm font-medium"></div>
                
                <!-- 🚀 Campos ocultos para no perder los IDs al guardar -->
                <input type="hidden" asp-for="DocId" />
                <input type="hidden" asp-for="CompanyId" />
                <input type="hidden" asp-for="CategoryId" />
                <input type="hidden" asp-for="DeptId" /> 
                <input type="hidden" asp-for="DocCode" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    
                    <!-- Columna Izquierda: Metadatos -->
                    <div class="md:border-r md:border-gray-200 md:pr-8">
                        <h5 class="text-gray-700 font-bold border-b border-gray-200 pb-2 mb-4 uppercase text-sm tracking-wider">Clasificación</h5>
                        
                        <!-- Categoría (Solo lectura) -->
                        <div class="mb-5">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Categoría (No editable)</label>
                            <input type="text" class="w-full border border-gray-300 bg-gray-100 rounded-md shadow-sm px-4 py-2 text-gray-500 cursor-not-allowed" value="@Model.Category?.CategoryName" disabled />
                        </div>

                        <!-- Departamento (Solo lectura para proteger el folio) -->
                        <div class="mb-5">
                            <label class="block text-sm font-bold text-gray-700 mb-1">Departamento Dueño (No editable)</label>
                            <input type="text" class="w-full border border-gray-300 bg-gray-100 rounded-md shadow-sm px-4 py-2 text-gray-500 cursor-not-allowed" value="@Model.Department?.DeptName" disabled />
                            <p class="text-xs text-gray-400 mt-1">La categoría y departamento definen el folio y las asignaciones, no se pueden alterar.</p>
                        </div>

                        <h5 class="text-gray-700 font-bold border-b border-gray-200 pb-2 mb-4 mt-8 uppercase text-sm tracking-wider">Detalles</h5>

                        <!-- Título -->
                        <div class="mb-5">
                            <label asp-for="DocName" class="block text-sm font-bold text-gray-700 mb-1">Título del Documento <span class="text-red-500">*</span></label>
                            <input asp-for="DocName" class="w-full border border-gray-300 rounded-md shadow-sm px-4 py-2 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" required />
                            <span asp-validation-for="DocName" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <!-- Descripción -->
                        <div class="mb-5">
                            <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1">Descripción / Objetivo</label>
                            <textarea asp-for="Description" rows="3" class="w-full border border-gray-300 rounded-md shadow-sm px-4 py-2 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500"></textarea>
                            <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        
                        <!-- Origen Externo -->
                        <div class="mt-4 flex items-start">
                            <div class="flex items-center h-5">
                                <input asp-for="IsExternal" type="checkbox" class="focus:ring-yellow-500 h-4 w-4 text-yellow-600 border-gray-300 rounded">
                            </div>
                            <div class="ml-3 text-sm">
                                <label asp-for="IsExternal" class="font-medium text-gray-700">Documento de origen externo</label>
                                <p class="text-gray-500">Ej. Manual de proveedor, Norma de cliente.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Columna Derecha: Archivo OPCIONAL -->
                    <div class="md:pl-4">
                        <h5 class="text-gray-700 font-bold border-b border-gray-200 pb-2 mb-4 uppercase text-sm tracking-wider">Reemplazar Archivo (Opcional)</h5>
                        
                        <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:bg-gray-100 transition duration-150 ease-in-out">
                            <i class="fa-solid fa-file-pdf text-4xl text-gray-400 mb-3"></i>
                            <label for="newFile" class="block text-sm font-bold text-gray-700 mb-2">Seleccionar Nuevo PDF</label>
                            
                            <!-- 🚀 NOTA: Le quitamos el "required" porque es opcional -->
                            <input type="file" name="newFile" id="newFile" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-yellow-50 file:text-yellow-700 hover:file:bg-yellow-100 mt-2" accept=".pdf" />
                            
                            <p class="text-xs text-gray-500 mt-3">Deja este campo vacío si solo quieres corregir el título o la descripción.</p>
                        </div>
                        
                        <div class="mt-6 bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded-r-md">
                            <div class="flex">
                                <div class="flex-shrink-0">
                                    <i class="fa-solid fa-triangle-exclamation text-yellow-500"></i>
                                </div>
                                <div class="ml-3">
                                    <h3 class="text-sm font-medium text-yellow-800">Modificación de Borrador</h3>
                                    <div class="mt-2 text-sm text-yellow-700">
                                        <p>Cualquier archivo nuevo que subas <strong>reemplazará</strong> de forma permanente al PDF actual de este borrador.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="border-gray-200 my-8" />

                <!-- Botones -->
                <div class="flex justify-end space-x-3">
                    <a asp-action="Index" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 transition">
                        Cancelar y Volver
                    </a>
                    <button type="submit" class="bg-yellow-500 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-yellow-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500 transition">
                        <i class="fa-solid fa-save mr-2"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}