@model QualityDoc.API.Models.Document

@{
    ViewData["Title"] = "Crear Documento";
}

<div class="max-w-6xl mx-auto mt-6">
    <div class="bg-white shadow-md rounded-lg overflow-hidden border border-gray-200">
        
        <!-- Header -->
        <div class="bg-blue-600 px-6 py-4">
            <h4 class="text-white text-lg font-semibold flex items-center">
                <i class="fa-solid fa-file-circle-plus mr-2"></i> Alta de Nuevo Documento
            </h4>
        </div>
        
        <div class="p-6 md:p-8">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm font-medium"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    
                    <!-- Columna Izquierda: Metadatos -->
                    <div class="md:border-r md:border-gray-200 md:pr-8">
                        <h5 class="text-gray-700 font-bold border-b border-gray-200 pb-2 mb-4 uppercase text-sm tracking-wider">Clasificación</h5>
                        
                        <div class="mb-5">
                            <label asp-for="CategoryId" class="block text-sm font-bold text-gray-700 mb-1">Categoría <span class="text-red-500">*</span></label>
                            <select asp-for="CategoryId" class="w-full border border-gray-300 rounded-md shadow-sm px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" asp-items="ViewBag.Categories" required>
                                <option value="">-- Seleccione una Categoría --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <div class="mb-5">
                            <label asp-for="DeptId" class="block text-sm font-bold text-gray-700 mb-1">Departamento Dueño <span class="text-red-500">*</span></label>
                            <select asp-for="DeptId" class="w-full border border-gray-300 rounded-md shadow-sm px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" asp-items="ViewBag.Departments" required>
                                <option value="">-- Seleccione un Departamento --</option>
                            </select>
                            <span asp-validation-for="DeptId" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <h5 class="text-gray-700 font-bold border-b border-gray-200 pb-2 mb-4 mt-8 uppercase text-sm tracking-wider">Detalles</h5>

                        <div class="mb-5">
                            <label asp-for="DocName" class="block text-sm font-bold text-gray-700 mb-1">Título del Documento <span class="text-red-500">*</span></label>
                            <input asp-for="DocName" class="w-full border border-gray-300 rounded-md shadow-sm px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Ej. Procedimiento de Auditoría Interna" required />
                            <span asp-validation-for="DocName" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <div class="mb-5">
                            <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1">Descripción / Objetivo</label>
                            <textarea asp-for="Description" rows="3" class="w-full border border-gray-300 rounded-md shadow-sm px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Breve descripción del propósito del documento..."></textarea>
                            <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        
                        <div class="mt-4 flex items-start">
                            <div class="flex items-center h-5">
                                <input asp-for="IsExternal" type="checkbox" class="focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300 rounded">
                            </div>
                            <div class="ml-3 text-sm">
                                <label asp-for="IsExternal" class="font-medium text-gray-700">Documento de origen externo</label>
                                <p class="text-gray-500">Ej. Manual de proveedor, Norma de cliente.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Columna Derecha: Archivo -->
                    <div class="md:pl-4">
                        <h5 class="text-gray-700 font-bold border-b border-gray-200 pb-2 mb-4 uppercase text-sm tracking-wider">Archivo (Versión 1.0)</h5>
                        
                        <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:bg-gray-100 transition duration-150 ease-in-out">
                            <i class="fa-solid fa-cloud-arrow-up text-4xl text-gray-400 mb-3"></i>
                            <label for="uploadedFile" class="block text-sm font-bold text-gray-700 mb-2">Seleccionar Archivo PDF/Word <span class="text-red-500">*</span></label>
                            
                            <input type="file" name="uploadedFile" id="uploadedFile" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 mt-2" accept=".pdf,.doc,.docx,.xls,.xlsx" required />
                            
                            <p class="text-xs text-gray-500 mt-3">Tamaño máximo recomendado: 10MB.</p>
                            
                            @if (ViewData.ModelState["uploadedFile"]?.Errors.Count > 0)
                            {
                                <span class="text-red-500 text-sm font-bold block mt-3">@ViewData.ModelState["uploadedFile"]?.Errors[0].ErrorMessage</span>
                            }
                        </div>
                        
                        <div class="mt-6 bg-blue-50 border-l-4 border-blue-400 p-4 rounded-r-md">
                            <div class="flex">
                                <div class="flex-shrink-0">
                                    <i class="fa-solid fa-circle-info text-blue-400"></i>
                                </div>
                                <div class="ml-3">
                                    <h3 class="text-sm font-medium text-blue-800">Flujo Automático</h3>
                                    <div class="mt-2 text-sm text-blue-700">
                                        <p>Al guardar, el sistema generará automáticamente el Folio (Ej. <em>PRO-001</em>) y registrará este archivo como la <strong>Versión 1.0</strong> en estatus de Borrador.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="border-gray-200 my-8" />

                <!-- Botones -->
                <div class="flex justify-end space-x-3">
                    <a asp-action="Index" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition">
                        Cancelar y Volver
                    </a>
                    <button type="submit" class="bg-blue-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition">
                        Guardar Documento
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}