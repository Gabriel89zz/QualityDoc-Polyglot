@model QualityDoc.API.Models.User

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="max-w-4xl mx-auto space-y-6">
    <nav class="flex mb-4 text-gray-500 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-blue-600 transition">Personal</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-gray-400">Modificar Perfil</li>
        </ol>
    </nav>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="bg-yellow-50 border-b border-yellow-100 p-6">
            <div class="flex items-center">
                <div class="bg-yellow-500 text-white h-10 w-10 flex items-center justify-center rounded-lg text-lg mr-4 shadow-sm">
                    <i class="fa-solid fa-user-pen"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-yellow-900">Actualizar Usuario</h2>
                    <p class="text-sm text-yellow-700">Modifica los permisos o datos de acceso de @Model.FullName.</p>
                </div>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="p-8">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6 bg-red-50 p-3 rounded-lg border border-red-100 font-semibold"></div>
            
            <input type="hidden" asp-for="UserId" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-6">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100 pb-2">Información de Cuenta</h3>
                    
                    <div>
                        <label asp-for="FullName" class="block text-sm font-bold text-gray-700 mb-2">Nombre Completo</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-signature"></i>
                            </span>
                            <input asp-for="FullName" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" />
                        </div>
                        <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Email" class="block text-sm font-bold text-gray-700 mb-2">Correo Electrónico</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-envelope"></i>
                            </span>
                            <input asp-for="Email" type="email" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" />
                        </div>
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="PasswordHash" class="block text-sm font-bold text-gray-700 mb-2">Nueva Contraseña</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-key"></i>
                            </span>
                            @* Inicializamos con asteriscos para que tu controlador detecte que no hubo cambios  *@
                            <input asp-for="PasswordHash" type="password" value="********" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" />
                        </div>
                        <p class="text-[10px] text-gray-400 mt-1 italic">Deja los asteriscos si no deseas cambiar la contraseña.</p>
                        <span asp-validation-for="PasswordHash" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="space-y-6">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100 pb-2">Configuración Operativa</h3>

                    @if (User.IsInRole("Super Administrador"))
                    {
                        <div>
                            <label asp-for="CompanyId" class="block text-sm font-bold text-gray-700 mb-2">Empresa</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                    <i class="fa-solid fa-building"></i>
                                </span>
                                <select asp-for="CompanyId" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none appearance-none" asp-items="ViewBag.CompanyId"></select>
                            </div>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="CompanyId" />
                    }

                    <div>
                        <label asp-for="DeptId" class="block text-sm font-bold text-gray-700 mb-2">Departamento</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-sitemap"></i>
                            </span>
                            <select asp-for="DeptId" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none appearance-none" asp-items="ViewBag.DeptId"></select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="RoleId" class="block text-sm font-bold text-gray-700 mb-2">Rol</label>
                            <select asp-for="RoleId" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none appearance-none" asp-items="ViewBag.RoleId"></select>
                        </div>

                        <div>
                            <label asp-for="Status" class="block text-sm font-bold text-gray-700 mb-2">Estado</label>
                            <select asp-for="Status" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none appearance-none font-bold">
                                <option value="Active">Activo</option>
                                <option value="Inactive">Suspendido</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-gray-100 flex justify-end space-x-3">
                <a asp-action="Index" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-bold py-2.5 px-6 rounded-lg transition duration-150">
                    Descartar Cambios
                </a>
                <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white text-sm font-bold py-2.5 px-6 rounded-lg shadow-md flex items-center transition duration-150">
                    <i class="fa-solid fa-rotate mr-2"></i> Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}