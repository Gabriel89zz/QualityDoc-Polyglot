@model QualityDoc.API.Models.User

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="max-w-4xl mx-auto space-y-6">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-brand transition-colors">Personal</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Modificar Perfil</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-amber-50 dark:bg-amber-900/10 border-b border-amber-100 dark:border-amber-900/20 p-6">
            <div class="flex items-center">
                <div class="bg-amber-500 text-white h-10 w-10 flex items-center justify-center rounded-xl text-lg mr-4 shadow-sm shadow-amber-500/20">
                    <i class="fa-solid fa-user-pen"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-amber-900 dark:text-amber-400">Actualizar Usuario</h2>
                    <p class="text-sm text-amber-700 dark:text-amber-500/80">Modifica los permisos o datos de acceso de @Model.FullName.</p>
                </div>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="p-8">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-transparent font-semibold"></div>
            
            <input type="hidden" asp-for="UserId" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-6">
                    <h3 class="text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-[#4a4b50] pb-2">Información de Cuenta</h3>
                    
                    <div>
                        <label asp-for="FullName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nombre Completo</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-signature"></i>
                            </span>
                            <input asp-for="FullName" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none" />
                        </div>
                        <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Email" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Correo Electrónico</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-envelope"></i>
                            </span>
                            <input asp-for="Email" type="email" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none" />
                        </div>
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="PasswordHash" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nueva Contraseña</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-key"></i>
                            </span>
                            <input asp-for="PasswordHash" type="password" value="********" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none" />
                        </div>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-1 italic">Deja los asteriscos si no deseas cambiar la contraseña.</p>
                        <span asp-validation-for="PasswordHash" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="space-y-6">
                    <h3 class="text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-[#4a4b50] pb-2">Configuración Operativa</h3>

                    @if (User.IsInRole("Super Administrador"))
                    {
                        <div>
                            <label asp-for="CompanyId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Empresa</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                    <i class="fa-solid fa-building"></i>
                                </span>
                                <select asp-for="CompanyId" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none appearance-none" asp-items="ViewBag.CompanyId"></select>
                            </div>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="CompanyId" />
                    }

                    <div>
                        <label asp-for="DeptId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Departamento</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-sitemap"></i>
                            </span>
                            <select asp-for="DeptId" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none appearance-none" asp-items="ViewBag.DeptId"></select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="RoleId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Rol</label>
                            <select asp-for="RoleId" class="w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none appearance-none" asp-items="ViewBag.RoleId"></select>
                        </div>

                        <div>
                            <label asp-for="Status" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Estado</label>
                            <select asp-for="Status" class="w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none appearance-none font-bold">
                                <option value="Active">Activo</option>
                                <option value="Inactive">Suspendido</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-slate-100 dark:border-[#4a4b50] flex justify-end space-x-3">
                <a asp-action="Index" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150">
                    Descartar Cambios
                </a>
                <button type="submit" class="bg-amber-500 hover:bg-amber-600 text-white text-sm font-bold py-2.5 px-6 rounded-xl shadow-md shadow-amber-500/20 flex items-center transition duration-150">
                    <i class="fa-solid fa-rotate mr-2"></i> Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}