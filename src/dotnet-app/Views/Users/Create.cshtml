@model QualityDoc.API.Models.User

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="max-w-4xl mx-auto space-y-6">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-brand transition-colors">Personal</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Registro de Usuario</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-brand/5 dark:bg-brand/10 border-b border-brand/10 dark:border-brand/20 p-6">
            <div class="flex items-center">
                <div class="bg-brand text-white h-10 w-10 flex items-center justify-center rounded-xl text-lg mr-4 shadow-sm shadow-brand/20">
                    <i class="fa-solid fa-user-plus"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-brand dark:text-brand-light">Crear Nuevo Usuario</h2>
                    <p class="text-sm text-slate-600 dark:text-slate-400">Asigna credenciales y permisos de acceso.</p>
                </div>
            </div>
        </div>

        <form asp-action="Create" method="post" class="p-8">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-transparent font-semibold"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-6">
                    <h3 class="text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-[#4a4b50] pb-2">Información Básica</h3>
                    
                    <div>
                        <label asp-for="FullName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nombre Completo</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-signature"></i>
                            </span>
                            <input asp-for="FullName" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white placeholder-slate-400 focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none" placeholder="Ej. Juan Pérez" />
                        </div>
                        <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Email" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Correo Electrónico</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-envelope"></i>
                            </span>
                            <input asp-for="Email" type="email" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white placeholder-slate-400 focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none" placeholder="usuario@empresa.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="PasswordHash" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Contraseña Inicial</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <input asp-for="PasswordHash" type="password" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white placeholder-slate-400 focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none" placeholder="Mínimo 8 caracteres" />
                        </div>
                        <span asp-validation-for="PasswordHash" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="space-y-6">
                    <h3 class="text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-[#4a4b50] pb-2">Asignación y Rol</h3>

                    @if (User.IsInRole("Super Administrador"))
                    {
                        <div>
                            <label asp-for="CompanyId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Empresa Cliente</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                    <i class="fa-solid fa-building"></i>
                                </span>
                                <select asp-for="CompanyId" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none appearance-none" asp-items="ViewBag.CompanyId">
                                    <option value="">-- Seleccionar Empresa --</option>
                                </select>
                            </div>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="CompanyId" value="@User.FindFirst("CompanyId")?.Value" />
                    }

                    <div>
                        <label asp-for="DeptId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Departamento / Área</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-sitemap"></i>
                            </span>
                            <select asp-for="DeptId" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none appearance-none" asp-items="ViewBag.DeptId">
                                <option value="">-- Seleccionar Área --</option>
                            </select>
                        </div>
                        <span asp-validation-for="DeptId" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="RoleId" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Rol de Usuario</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                <i class="fa-solid fa-shield-halved"></i>
                            </span>
                            <select asp-for="RoleId" class="pl-10 w-full rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] px-4 py-2.5 text-slate-700 dark:text-white focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 transition outline-none appearance-none" asp-items="ViewBag.RoleId">
                                <option value="">-- Seleccionar Nivel --</option>
                            </select>
                        </div>
                        <span asp-validation-for="RoleId" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-slate-100 dark:border-[#4a4b50] flex justify-end space-x-3">
                <a asp-action="Index" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150">
                    Cancelar
                </a>
                <button type="submit" class="bg-brand hover:bg-brand-hover text-white text-sm font-bold py-2.5 px-6 rounded-xl shadow-md shadow-brand/20 flex items-center transition duration-150">
                    <i class="fa-solid fa-user-check mr-2"></i> Registrar Usuario
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}