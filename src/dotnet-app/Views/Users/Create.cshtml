@model QualityDoc.API.Models.User

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="max-w-4xl mx-auto space-y-6">
    <nav class="flex mb-4 text-gray-500 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-blue-600 transition">Personal</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-gray-400">Registro de Usuario</li>
        </ol>
    </nav>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="bg-blue-50 border-b border-blue-100 p-6">
            <div class="flex items-center">
                <div class="bg-blue-600 text-white h-10 w-10 flex items-center justify-center rounded-lg text-lg mr-4 shadow-sm">
                    <i class="fa-solid fa-user-plus"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-blue-900">Crear Nuevo Usuario</h2>
                    <p class="text-sm text-blue-700">Asigna credenciales y permisos de acceso.</p>
                </div>
            </div>
        </div>

        <form asp-action="Create" method="post" class="p-8">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6 bg-red-50 p-3 rounded-lg border border-red-100 font-semibold"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <div class="space-y-6">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100 pb-2">Información Básica</h3>
                    
                    <div>
                        <label asp-for="FullName" class="block text-sm font-bold text-gray-700 mb-2">Nombre Completo</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-signature"></i>
                            </span>
                            <input asp-for="FullName" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" placeholder="Ej. Juan Pérez" />
                        </div>
                        <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Email" class="block text-sm font-bold text-gray-700 mb-2">Correo Electrónico</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-envelope"></i>
                            </span>
                            <input asp-for="Email" type="email" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" placeholder="usuario@empresa.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="PasswordHash" class="block text-sm font-bold text-gray-700 mb-2">Contraseña Inicial</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <input asp-for="PasswordHash" type="password" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" placeholder="Mínimo 8 caracteres" />
                        </div>
                        <span asp-validation-for="PasswordHash" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="space-y-6">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100 pb-2">Asignación y Rol</h3>

                    @if (User.IsInRole("Super Administrador"))
                    {
                        <div>
                            <label asp-for="CompanyId" class="block text-sm font-bold text-gray-700 mb-2">Empresa Cliente</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                    <i class="fa-solid fa-building"></i>
                                </span>
                                <select asp-for="CompanyId" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none appearance-none" asp-items="ViewBag.CompanyId">
                                    <option value="">-- Seleccionar Empresa --</option>
                                </select>
                            </div>
                        </div>
                    }
                    else
                    {
                        @* Para Admins de Empresa, ocultamos el selector y enviamos su CompanyId actual *@
                        <input type="hidden" asp-for="CompanyId" value="@User.FindFirst("CompanyId")?.Value" />
                    }

                    <div>
                        <label asp-for="DeptId" class="block text-sm font-bold text-gray-700 mb-2">Departamento / Área</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-sitemap"></i>
                            </span>
                            <select asp-for="DeptId" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none appearance-none" asp-items="ViewBag.DeptId">
                                <option value="">-- Seleccionar Área --</option>
                            </select>
                        </div>
                        <span asp-validation-for="DeptId" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="RoleId" class="block text-sm font-bold text-gray-700 mb-2">Rol de Usuario</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                                <i class="fa-solid fa-shield-halved"></i>
                            </span>
                            <select asp-for="RoleId" class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none appearance-none" asp-items="ViewBag.RoleId">
                                <option value="">-- Seleccionar Nivel --</option>
                            </select>
                        </div>
                        <span asp-validation-for="RoleId" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-gray-100 flex justify-end space-x-3">
                <a asp-action="Index" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-bold py-2.5 px-6 rounded-lg transition duration-150">
                    Cancelar
                </a>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold py-2.5 px-6 rounded-lg shadow-md flex items-center transition duration-150">
                    <i class="fa-solid fa-user-check mr-2"></i> Registrar Usuario
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}