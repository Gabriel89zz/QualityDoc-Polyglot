@model QualityDoc.API.Models.User

@{
    ViewData["Title"] = "Suspender Usuario";
}

<div class="max-w-2xl mx-auto">
    <nav class="flex mb-4 text-gray-500 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-blue-600 transition">Personal</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-gray-400">Confirmar Suspensión</li>
        </ol>
    </nav>

    <div class="bg-white rounded-xl shadow-sm border border-red-100 overflow-hidden">
        <div class="bg-red-50 border-b border-red-100 p-6 flex items-center">
            <div class="bg-red-600 text-white h-12 w-12 flex items-center justify-center rounded-lg text-xl mr-4 shadow-md">
                <i class="fa-solid fa-user-slash"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-red-900">¿Suspender acceso al sistema?</h2>
                <p class="text-sm text-red-700">El usuario ya no podrá iniciar sesión, pero sus registros históricos se conservarán.</p>
            </div>
        </div>

        <div class="p-8">
            <div class="mb-8 p-4 bg-gray-50 rounded-lg border border-gray-100 flex items-center">
                <div class="h-12 w-12 rounded-full bg-red-100 text-red-600 flex items-center justify-center font-bold text-lg mr-4 border border-red-200">
                    @(string.IsNullOrEmpty(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper())
                </div>
                <div>
                    <p class="text-lg font-bold text-gray-800">@Model.FullName</p>
                    <p class="text-sm text-gray-500">@Model.Role?.RoleName en @(Model.Company?.LegalName ?? "Empresa Local")</p>
                </div>
            </div>

            <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i class="fa-solid fa-circle-info text-yellow-400"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-yellow-700 font-medium">
                            Nota de Calidad:
                        </p>
                        <p class="text-xs text-yellow-600 mt-1">
                            Debido a los requerimientos de la norma <span class="font-bold">IATF 16949</span>, el usuario pasará a estado "Inactivo". Sus firmas electrónicas y participaciones en documentos previos no se verán afectadas.
                        </p>
                    </div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="UserId" />
                
                <div class="flex justify-end space-x-3">
                    <a asp-action="Index" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-bold py-2 px-6 rounded-lg transition duration-150">
                        No, mantener activo
                    </a>
                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white text-sm font-bold py-2 px-6 rounded-lg shadow-sm flex items-center transition duration-150">
                        <i class="fa-solid fa-power-off mr-2"></i> Confirmar Suspensión
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>