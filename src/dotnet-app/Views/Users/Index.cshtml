@model IEnumerable<QualityDoc.API.Models.User>

@{
    ViewData["Title"] = "Directorio de Personal";
}

<div class="max-w-7xl mx-auto space-y-6">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white dark:bg-[#323338] p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] transition-colors duration-300">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-white">Personal Registrado</h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Directorio de usuarios y control de accesos al sistema.</p>
        </div>
        <div class="mt-4 sm:mt-0">
            <a asp-action="Create" class="bg-brand hover:bg-brand-hover text-white font-bold py-2.5 px-5 rounded-xl shadow-md flex items-center transition duration-200">
                <i class="fa-solid fa-user-plus mr-2"></i> Nuevo Usuario
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 rounded-r-xl shadow-sm border border-y-red-100 border-r-red-100 dark:border-transparent">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <i class="fa-solid fa-triangle-exclamation text-red-500 text-lg"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-red-700 dark:text-red-400 font-bold">
                        @TempData["ErrorMessage"]
                    </p>
                </div>
            </div>
        </div>
    }

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50 dark:bg-[#2a2b2e] text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider transition-colors duration-300">
                    <tr>
                        <th class="p-4 font-semibold">Usuario</th>
                        <th class="p-4 font-semibold">Departamento</th>
                        <th class="p-4 font-semibold">Rol de Acceso</th>
                        <th class="p-4 font-semibold">Estado</th>
                        <th class="p-4 font-semibold text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50] text-sm">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="p-10 text-center text-slate-500 dark:text-slate-400">
                                <i class="fa-regular fa-folder-open text-4xl mb-3 text-slate-300 dark:text-slate-600 block"></i>
                                No hay usuarios registrados aún.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition duration-150">
                                <td class="p-4">
                                    <div class="flex items-center">
                                        <div class="h-10 w-10 rounded-full bg-brand/10 border border-brand/20 flex items-center justify-center text-brand font-bold mr-3 shadow-sm">
                                            @(string.IsNullOrEmpty(item.FullName) ? "U" : item.FullName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <p class="font-bold text-slate-800 dark:text-white">@item.FullName</p>
                                            <p class="text-xs text-slate-500 dark:text-slate-400">@item.Email</p>
                                        </div>
                                    </div>
                                </td>

                                <td class="p-4">
                                    <div class="flex items-center text-slate-700 dark:text-slate-300">
                                        <i class="fa-solid fa-sitemap text-slate-400 dark:text-slate-500 w-5"></i>
                                        <span class="ml-2">@(item.Department?.DeptName ?? "Sin asignar")</span>
                                    </div>
                                </td>

                                <td class="p-4">
                                    <span class="bg-slate-100 dark:bg-[#2a2b2e] text-slate-700 dark:text-slate-300 px-3 py-1 rounded-md text-xs font-semibold border border-slate-200 dark:border-[#4a4b50]">
                                        <i class="fa-solid fa-shield-halved mr-1 text-slate-500 dark:text-slate-400"></i>
                                        @(item.Role?.RoleName ?? "Sin Rol")
                                    </span>
                                </td>

                                <td class="p-4">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="inline-flex items-center bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 px-2.5 py-1 rounded-full text-xs font-bold border border-green-200 dark:border-green-800/30">
                                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1.5"></span> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 px-2.5 py-1 rounded-full text-xs font-bold border border-red-200 dark:border-red-800/30">
                                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full mr-1.5"></span> Suspendido
                                        </span>
                                    }
                                </td>

                                <td class="p-4 text-center flex justify-center items-center space-x-4">
                                    <a asp-action="Details" asp-route-id="@item.UserId" class="text-slate-400 hover:text-brand dark:hover:text-brand transition" title="Ver Detalles">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    
                                    @if (item.Status == "Active")
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.UserId" class="text-slate-400 hover:text-amber-500 transition" title="Editar Registro">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.UserId" method="post" class="inline-block m-0 p-0">
                                            <button type="submit" class="text-slate-400 hover:text-red-600 transition bg-transparent border-none p-0 cursor-pointer" title="Suspender Acceso" onclick="return confirm('¿Estás seguro de suspender el acceso a este usuario?');">
                                                <i class="fa-solid fa-power-off"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-slate-300 dark:text-slate-600 cursor-not-allowed" title="Restaura al usuario para poder editar">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </span>
                                        <form asp-action="Reactivate" asp-route-id="@item.UserId" method="post" class="inline-block m-0 p-0">
                                            <button type="submit" class="text-slate-400 hover:text-green-500 transition bg-transparent border-none p-0 cursor-pointer" title="Reactivar Acceso" onclick="return confirm('¿Deseas volver a activar a este usuario?');">
                                                <i class="fa-solid fa-arrow-rotate-left"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        
        <div class="bg-slate-50 dark:bg-[#2a2b2e] px-4 py-3 border-t border-slate-200 dark:border-[#4a4b50] flex items-center justify-between sm:px-6 transition-colors duration-300">
            <div class="text-sm text-slate-500 dark:text-slate-400">
                Mostrando <span class="font-bold text-slate-800 dark:text-white">@Model.Count()</span> registros
            </div>
        </div>
    </div>
</div>