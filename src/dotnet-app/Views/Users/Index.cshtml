@model IEnumerable<QualityDoc.API.Models.User>

@{
    ViewData["Title"] = "Directorio de Personal";
}

<div class="max-w-7xl mx-auto space-y-6">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white p-6 rounded-xl shadow-sm border border-gray-100">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Personal Registrado</h1>
            <p class="text-gray-500 text-sm mt-1">Directorio de usuarios y control de accesos al sistema.</p>
        </div>
        <div class="mt-4 sm:mt-0">
            <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-5 rounded-lg shadow-md flex items-center transition duration-200">
                <i class="fa-solid fa-user-plus mr-2"></i> Nuevo Usuario
            </a>
        </div>
    </div>

    <!-- 🚨 Lector de Errores TempData -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg shadow-sm">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <i class="fa-solid fa-triangle-exclamation text-red-500 text-lg"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-red-700 font-bold">
                        @TempData["ErrorMessage"]
                    </p>
                </div>
            </div>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider">
                    <tr>
                        <th class="p-4 font-semibold">Usuario</th>
                        <th class="p-4 font-semibold">Departamento</th>
                        <th class="p-4 font-semibold">Rol de Acceso</th>
                        <th class="p-4 font-semibold">Estado</th>
                        <th class="p-4 font-semibold text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-sm">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="p-8 text-center text-gray-500">
                                <i class="fa-regular fa-folder-open text-4xl mb-3 text-gray-300 block"></i>
                                No hay usuarios registrados aún.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-50 transition duration-150">
                                <td class="p-4">
                                    <div class="flex items-center">
                                        <div class="h-10 w-10 rounded-full bg-blue-100 border border-blue-200 flex items-center justify-center text-blue-700 font-bold mr-3 shadow-sm">
                                            @(string.IsNullOrEmpty(item.FullName) ? "U" : item.FullName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <p class="font-bold text-gray-800">@item.FullName</p>
                                            <p class="text-xs text-gray-500">@item.Email</p>
                                        </div>
                                    </div>
                                </td>

                                <td class="p-4">
                                    <div class="flex items-center text-gray-700">
                                        <i class="fa-solid fa-sitemap text-gray-400 w-5"></i>
                                        <span class="ml-2">@(item.Department?.DeptName ?? "Sin asignar")</span>
                                    </div>
                                </td>

                                <td class="p-4">
                                    <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-md text-xs font-semibold border border-gray-200">
                                        <i class="fa-solid fa-shield-halved mr-1 text-gray-500"></i>
                                        @(item.Role?.RoleName ?? "Sin Rol")
                                    </span>
                                </td>

                                <td class="p-4">
                                    @if (item.Status == "Active")
                                    {
                                        <span class="inline-flex items-center bg-green-50 text-green-700 px-2.5 py-1 rounded-full text-xs font-bold border border-green-200">
                                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1.5"></span> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center bg-red-50 text-red-700 px-2.5 py-1 rounded-full text-xs font-bold border border-red-200">
                                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full mr-1.5"></span> Suspendido
                                        </span>
                                    }
                                </td>

                                <td class="p-4 text-center flex justify-center items-center space-x-4">
                                    
                                    <!-- Ver Detalles siempre está activo -->
                                    <a asp-action="Details" asp-route-id="@item.UserId" class="text-gray-400 hover:text-blue-600 transition" title="Ver Detalles">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    
                                    @if (item.Status == "Active")
                                    {
                                        <!-- Botón Editar (Activo) -->
                                        <a asp-action="Edit" asp-route-id="@item.UserId" class="text-gray-400 hover:text-yellow-500 transition" title="Editar Registro">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        
                                        <!-- Botón de Desactivar (POST) -->
                                        <form asp-action="Delete" asp-route-id="@item.UserId" method="post" class="inline-block m-0 p-0">
                                            <button type="submit" class="text-gray-400 hover:text-red-600 transition bg-transparent border-none p-0 cursor-pointer" title="Suspender Acceso" onclick="return confirm('¿Estás seguro de suspender el acceso a este usuario?');">
                                                <i class="fa-solid fa-power-off"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <!-- Botón Editar (Bloqueado) -->
                                        <span class="text-gray-300 cursor-not-allowed" title="Restaura al usuario para poder editar su registro">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </span>

                                        <!-- Botón de Reactivar (POST) -->
                                        <form asp-action="Reactivate" asp-route-id="@item.UserId" method="post" class="inline-block m-0 p-0">
                                            <button type="submit" class="text-gray-400 hover:text-green-600 transition bg-transparent border-none p-0 cursor-pointer" title="Reactivar Acceso" onclick="return confirm('¿Deseas volver a activar a este usuario?');">
                                                <i class="fa-solid fa-arrow-rotate-left"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        
        <div class="bg-gray-50 px-4 py-3 border-t border-gray-100 flex items-center justify-between sm:px-6">
            <div class="text-sm text-gray-500">
                Mostrando <span class="font-medium">@Model.Count()</span> registros
            </div>
        </div>
    </div>
</div>