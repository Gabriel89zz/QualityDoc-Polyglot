@model QualityDoc.API.Models.Norm

@{
    ViewData["Title"] = "Editar Normativa";
}

<div class="max-w-3xl mx-auto">
    <!-- Breadcrumb de navegación -->
    <nav class="flex mb-4 text-gray-500 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-blue-600 transition">Catálogo ISO</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-gray-400">Editar Normativa</li>
        </ol>
    </nav>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <!-- Encabezado del Formulario con Insignia Dinámica -->
        <div class="bg-blue-50 border-b border-blue-100 p-6 flex justify-between items-center">
            <div class="flex items-center">
                <div class="bg-blue-600 text-white h-10 w-10 flex items-center justify-center rounded-lg text-lg mr-4 shadow-sm">
                    <i class="fa-solid fa-pen-to-square"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-blue-900">Editar Normativa</h2>
                    <p class="text-sm text-blue-700">Actualizando los datos de la ficha técnica.</p>
                </div>
            </div>
            <div>
                @if (Model.Status == "Active")
                {
                    <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold border border-green-200">
                        Vigente
                    </span>
                }
                else
                {
                    <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-bold border border-red-200">
                        Obsoleta
                    </span>
                }
            </div>
        </div>

        <!-- Cuerpo del Formulario -->
        <form asp-action="Edit" class="p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded-lg border border-red-100 mb-4"></div>
            
            <!-- 🚀 MUY IMPORTANTE: Campos ocultos para mantener la integridad en EF Core -->
            <input type="hidden" asp-for="NormId" />
            <input type="hidden" asp-for="Status" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Nombre de la Norma -->
                <div>
                    <label asp-for="NormName" class="block text-sm font-bold text-gray-700 mb-1">Nombre de la Normativa <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-tag text-gray-400"></i>
                        </div>
                        <input asp-for="NormName" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition bg-gray-50" required />
                    </div>
                    <span asp-validation-for="NormName" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Año de Publicación (ReleaseYear) -->
                <div>
                    <label asp-for="ReleaseYear" class="block text-sm font-bold text-gray-700 mb-1">Año / Versión <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-regular fa-calendar-check text-gray-400"></i>
                        </div>
                        <input asp-for="ReleaseYear" type="number" min="1950" max="2100" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition bg-gray-50" required />
                    </div>
                    <span asp-validation-for="ReleaseYear" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <!-- Información de Auditoría en Modo Lectura -->
            <div class="bg-gray-50 p-4 rounded-lg border border-gray-100 flex items-center justify-between mt-4">
                <div class="flex items-center text-xs text-gray-500">
                    <i class="fa-solid fa-circle-info mr-2 text-blue-400"></i>
                    <span>La fecha de creación y los registros de auditoría se mantendrán intactos.</span>
                </div>
            </div>

            <!-- Botones de Acción -->
            <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-100 mt-6">
                <a asp-action="Index" class="text-gray-500 hover:text-gray-800 font-medium text-sm px-4 py-2 rounded-lg hover:bg-gray-100 transition">
                    Cancelar
                </a>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg shadow-sm transition flex items-center">
                    <i class="fa-solid fa-floppy-disk mr-2"></i> Actualizar Ficha
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}