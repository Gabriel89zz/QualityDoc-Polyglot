@model QualityDoc.API.Models.Norm

@{
    ViewData["Title"] = "Registrar Normativa";
}

<div class="max-w-4xl mx-auto space-y-6 mt-4">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-brand transition-colors">Catálogo ISO</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Nueva Normativa</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="bg-brand/5 dark:bg-brand/10 border-b border-brand/10 dark:border-brand/20 p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div class="flex items-center">
                <div class="bg-brand text-white h-12 w-12 flex items-center justify-center rounded-xl text-xl mr-4 shadow-sm shadow-brand/20">
                    <i class="fa-solid fa-book-medical"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-brand dark:text-brand-light">Registrar Nueva Normativa</h2>
                    <p class="text-sm text-slate-600 dark:text-slate-400">Añade un estándar al catálogo global (Ej. ISO 14001, IATF).</p>
                </div>
            </div>
        </div>

        <form asp-action="Create" class="p-6 md:p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-sm font-bold text-red-500 bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-100 dark:border-transparent mb-6"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <label asp-for="NormName" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Nombre de la Normativa <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-tag text-slate-400"></i>
                        </div>
                        <input asp-for="NormName" class="w-full pl-10 pr-4 py-2.5 rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] text-slate-700 dark:text-white placeholder-slate-400 focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none transition" placeholder="Ej. ISO 9001" required />
                    </div>
                    <span asp-validation-for="NormName" class="text-xs text-red-500 font-semibold mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="ReleaseYear" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Año / Versión <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-regular fa-calendar-check text-slate-400"></i>
                        </div>
                        <input asp-for="ReleaseYear" type="number" min="1950" max="2100" class="w-full pl-10 pr-4 py-2.5 rounded-xl bg-white dark:bg-[#2a2b2e] border border-slate-300 dark:border-[#4a4b50] text-slate-700 dark:text-white placeholder-slate-400 font-mono font-bold focus:border-brand dark:focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none transition" placeholder="Ej. 2015" required />
                    </div>
                    <span asp-validation-for="ReleaseYear" class="text-xs text-red-500 font-semibold mt-1 block"></span>
                </div>
            </div>

            <div class="flex items-center justify-end space-x-3 pt-6 mt-6 border-t border-slate-100 dark:border-[#4a4b50] transition-colors duration-300">
                <a asp-action="Index" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm font-bold py-2.5 px-6 rounded-xl transition duration-150">
                    Cancelar
                </a>
                <button type="submit" class="bg-brand hover:bg-brand-hover text-white font-bold py-2.5 px-6 rounded-xl shadow-md shadow-brand/20 transition duration-200 flex items-center text-sm">
                    <i class="fa-solid fa-floppy-disk mr-2"></i> Guardar Normativa
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}