@model IEnumerable<QualityDoc.API.Models.DocumentApproval>

@{
    ViewData["Title"] = "Centro de Tareas";
    
    // Extraemos las listas del ViewBag
    var rechazados = ViewBag.RejectedDocs as IEnumerable<QualityDoc.API.Models.DocumentVersion>;
    var olvidados = ViewBag.ForgottenDrafts as IEnumerable<QualityDoc.API.Models.DocumentVersion>;

    // Contadores para las notificaciones
    int countFirmas = Model?.Count() ?? 0;
    int countRechazados = rechazados?.Count() ?? 0;
    int countOlvidados = olvidados?.Count() ?? 0;
}

<div class="max-w-7xl mx-auto space-y-6 mt-4">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white dark:bg-[#323338] p-6 rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] transition-colors duration-300">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-white flex items-center">
                <div class="w-10 h-10 rounded-xl bg-brand/10 flex items-center justify-center mr-3 border border-brand/20">
                    <i class="fa-solid fa-list-check text-brand"></i>
                </div>
                Mi Centro de Tareas
            </h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Gestiona tus firmas pendientes, atiende rechazos y envía tus borradores al flujo.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 dark:bg-green-900/20 border-l-4 border-green-500 p-4 rounded-r-xl shadow-sm border border-y-green-100 border-r-green-100 dark:border-transparent transition-colors duration-300">
            <div class="flex items-center">
                <i class="fa-solid fa-circle-check text-green-500 text-xl mr-3"></i>
                <p class="text-sm font-bold text-green-700 dark:text-green-400">@TempData["SuccessMessage"]</p>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 rounded-r-xl shadow-sm border border-y-red-100 border-r-red-100 dark:border-transparent transition-colors duration-300">
            <div class="flex items-center">
                <i class="fa-solid fa-triangle-exclamation text-red-500 text-xl mr-3"></i>
                <p class="text-sm font-bold text-red-700 dark:text-red-400">@TempData["ErrorMessage"]</p>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <div onclick="showTab('firmas')" id="tab-btn-firmas" class="cursor-pointer bg-white dark:bg-[#323338] border-2 border-brand rounded-2xl p-5 flex items-center justify-between shadow-sm transition-all transform hover:-translate-y-1 hover:shadow-md duration-200">
            <div class="flex items-center">
                <div class="w-12 h-12 rounded-full bg-brand/10 flex items-center justify-center mr-4 border border-brand/20">
                    <i class="fa-solid fa-pen-nib text-brand text-xl"></i>
                </div>
                <div>
                    <p class="text-xs text-slate-500 dark:text-slate-400 font-bold uppercase tracking-widest mb-1">Por Firmar</p>
                    <p class="text-3xl font-black text-slate-800 dark:text-white leading-none">@countFirmas</p>
                </div>
            </div>
            @if(countFirmas > 0)
            {
                <span class="relative flex h-4 w-4">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-4 w-4 bg-brand"></span>
                </span>
            }
        </div>

        <div onclick="showTab('rechazos')" id="tab-btn-rechazos" class="cursor-pointer bg-white dark:bg-[#323338] border border-slate-200 dark:border-[#4a4b50] hover:border-red-400 dark:hover:border-red-500/50 rounded-2xl p-5 flex items-center justify-between shadow-sm transition-all transform hover:-translate-y-1 hover:shadow-md duration-200">
            <div class="flex items-center">
                <div class="w-12 h-12 rounded-full bg-red-50 dark:bg-red-900/20 flex items-center justify-center mr-4 border border-red-100 dark:border-red-800/30">
                    <i class="fa-solid fa-triangle-exclamation text-red-500 text-xl"></i>
                </div>
                <div>
                    <p class="text-xs text-slate-500 dark:text-slate-400 font-bold uppercase tracking-widest mb-1">Rechazados</p>
                    <p class="text-3xl font-black text-slate-800 dark:text-white leading-none">@countRechazados</p>
                </div>
            </div>
            @if(countRechazados > 0)
            {
                <span class="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-[10px] uppercase font-bold px-3 py-1.5 rounded-full border border-red-200 dark:border-red-800/30 shadow-sm flex items-center">
                    <i class="fa-solid fa-bell mr-1.5"></i> Corregir
                </span>
            }
        </div>

        <div onclick="showTab('olvidados')" id="tab-btn-olvidados" class="cursor-pointer bg-white dark:bg-[#323338] border border-slate-200 dark:border-[#4a4b50] hover:border-amber-400 dark:hover:border-amber-500/50 rounded-2xl p-5 flex items-center justify-between shadow-sm transition-all transform hover:-translate-y-1 hover:shadow-md duration-200">
            <div class="flex items-center">
                <div class="w-12 h-12 rounded-full bg-amber-50 dark:bg-amber-900/20 flex items-center justify-center mr-4 border border-amber-100 dark:border-amber-800/30">
                    <i class="fa-solid fa-file-circle-exclamation text-amber-500 text-xl"></i>
                </div>
                <div>
                    <p class="text-xs text-slate-500 dark:text-slate-400 font-bold uppercase tracking-widest mb-1">Borradores</p>
                    <p class="text-3xl font-black text-slate-800 dark:text-white leading-none">@countOlvidados</p>
                </div>
            </div>
            @if(countOlvidados > 0)
            {
                <span class="bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 text-[10px] uppercase font-bold px-3 py-1.5 rounded-full border border-amber-200 dark:border-amber-800/30 shadow-sm flex items-center">
                    Sin Enviar
                </span>
            }
        </div>
    </div>

    <div id="tab-firmas" class="block bg-white dark:bg-[#323338] shadow-sm rounded-2xl border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        <div class="px-6 py-5 border-b border-brand/10 dark:border-brand/20 bg-brand/5 dark:bg-brand/10 flex items-center">
            <h3 class="text-sm font-bold text-brand dark:text-brand-light uppercase tracking-widest"><i class="fa-solid fa-pen-nib mr-2"></i> Documentos en espera de tu firma</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 dark:divide-[#4a4b50]">
                <thead class="bg-slate-50 dark:bg-[#2a2b2e]">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Documento</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Área</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Tu Tarea</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Fecha</th>
                        <th class="px-6 py-4 text-right text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Acción</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50]">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition-colors duration-150">
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10 flex items-center justify-center bg-blue-50 dark:bg-blue-900/20 rounded-xl border border-blue-100 dark:border-blue-800/30 text-blue-600 dark:text-blue-400">
                                            <i class="fa-solid fa-file-pdf text-xl"></i>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-black text-brand dark:text-brand-light">@item.DocumentVersion?.Document?.DocCode</div>
                                            <div class="text-sm font-semibold text-slate-700 dark:text-slate-300 max-w-xs truncate" title="@item.DocumentVersion?.Document?.DocName">
                                                @item.DocumentVersion?.Document?.DocName (v @item.DocumentVersion?.VersionNum)
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-slate-100 dark:bg-[#2a2b2e] text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-[#4a4b50] shadow-sm">
                                        <i class="fa-solid fa-building-user mr-1.5 text-slate-400"></i> @item.DocumentVersion?.Document?.Department?.DeptName
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-brand/10 dark:bg-brand/20 text-brand dark:text-brand-light border border-brand/20 dark:border-brand/30">
                                        <i class="fa-solid fa-signature mr-1.5"></i> @item.StepType
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400 font-medium">@item.CreatedAt.ToLocalTime().ToString("dd/MMM/yyyy HH:mm")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a asp-action="Review" asp-route-id="@item.ApprovalId" class="text-white bg-brand hover:bg-brand-hover px-4 py-2.5 rounded-xl shadow-md shadow-brand/20 transition inline-flex items-center font-bold">
                                        Evaluar <i class="fa-solid fa-arrow-right-to-bracket ml-2"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-16 text-center text-slate-400 dark:text-slate-500">
                                <div class="flex flex-col items-center justify-center">
                                    <i class="fa-solid fa-mug-hot text-5xl mb-4 text-slate-300 dark:text-slate-600"></i>
                                    <h3 class="text-lg font-bold text-slate-800 dark:text-white mb-1">¡Todo al día!</h3>
                                    <p class="text-sm font-medium">No tienes ningún documento pendiente de firma en este momento.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div id="tab-rechazos" class="hidden bg-white dark:bg-[#323338] shadow-sm rounded-2xl border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        <div class="px-6 py-5 border-b border-red-100 dark:border-red-900/20 bg-red-50 dark:bg-red-900/10 flex items-center">
            <h3 class="text-sm font-bold text-red-700 dark:text-red-400 uppercase tracking-widest"><i class="fa-solid fa-triangle-exclamation mr-2"></i> Documentos Devueltos para Corrección</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 dark:divide-[#4a4b50]">
                <thead class="bg-slate-50 dark:bg-[#2a2b2e]">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Documento</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Versión Rechazada</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Fecha Rechazo</th>
                        <th class="px-6 py-4 text-right text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Acción</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50]">
                    @if (rechazados != null && rechazados.Any())
                    {
                        foreach (var item in rechazados)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition-colors duration-150">
                                <td class="px-6 py-4">
                                    <div class="text-sm font-black text-brand dark:text-brand-light">@item.Document?.DocCode</div>
                                    <div class="text-sm font-semibold text-slate-700 dark:text-slate-300 max-w-xs truncate">@item.Document?.DocName</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-slate-100 dark:bg-[#2a2b2e] text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-[#4a4b50] shadow-sm">
                                        v @item.VersionNum
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400 font-medium">@(item.UpdatedAt?.ToLocalTime().ToString("dd/MMM/yyyy") ?? item.CreatedAt.ToLocalTime().ToString("dd/MMM/yyyy"))</td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a asp-controller="Documents" asp-action="Details" asp-route-id="@item.DocId" class="text-red-600 dark:text-red-400 hover:text-white border border-red-200 dark:border-red-800/50 hover:bg-red-500 dark:hover:bg-red-600 px-4 py-2.5 rounded-xl shadow-sm transition inline-flex items-center font-bold">
                                        <i class="fa-regular fa-comment-dots mr-2"></i> Ver Comentarios
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500">
                                <p class="font-medium">No tienes documentos rechazados. ¡Buen trabajo!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div id="tab-olvidados" class="hidden bg-white dark:bg-[#323338] shadow-sm rounded-2xl border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        <div class="px-6 py-5 border-b border-amber-100 dark:border-amber-900/20 bg-amber-50 dark:bg-amber-900/10 flex items-center">
            <h3 class="text-sm font-bold text-amber-700 dark:text-amber-400 uppercase tracking-widest"><i class="fa-solid fa-file-circle-exclamation mr-2"></i> Borradores que no has enviado a flujo</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 dark:divide-[#4a4b50]">
                <thead class="bg-slate-50 dark:bg-[#2a2b2e]">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Documento</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Versión Creada</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Fecha</th>
                        <th class="px-6 py-4 text-right text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Acción</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-[#4a4b50]">
                    @if (olvidados != null && olvidados.Any())
                    {
                        foreach (var item in olvidados)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition-colors duration-150">
                                <td class="px-6 py-4">
                                    <div class="text-sm font-black text-brand dark:text-brand-light">@item.Document?.DocCode</div>
                                    <div class="text-sm font-semibold text-slate-700 dark:text-slate-300 max-w-xs truncate">@item.Document?.DocName</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-slate-100 dark:bg-[#2a2b2e] text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-[#4a4b50] shadow-sm">
                                        v @item.VersionNum
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400 font-medium">@item.CreatedAt.ToLocalTime().ToString("dd/MMM/yyyy")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a asp-controller="Documents" asp-action="Details" asp-route-id="@item.DocId" class="text-amber-600 dark:text-amber-400 hover:text-white border border-amber-200 dark:border-amber-800/50 hover:bg-amber-500 dark:hover:bg-amber-600 px-4 py-2.5 rounded-xl shadow-sm transition inline-flex items-center font-bold">
                                        <i class="fa-solid fa-paper-plane mr-2"></i> Iniciar Flujo
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center text-slate-400 dark:text-slate-500">
                                <p class="font-medium">No tienes borradores olvidados.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showTab(tabName) {
            // Ocultar todas las tablas y quitar la clase 'block'
            ['firmas', 'rechazos', 'olvidados'].forEach(t => {
                document.getElementById('tab-' + t).classList.add('hidden');
                document.getElementById('tab-' + t).classList.remove('block');
                
                // Resetear el borde de las tarjetas para ambos modos (claro y oscuro)
                let btn = document.getElementById('tab-btn-' + t);
                btn.classList.remove('border-2', 'border-brand', 'border-red-500', 'border-amber-500');
                btn.classList.add('border', 'border-slate-200', 'dark:border-[#4a4b50]');
            });

            // Mostrar la tabla clickeada
            document.getElementById('tab-' + tabName).classList.remove('hidden');
            document.getElementById('tab-' + tabName).classList.add('block');
            
            // Resaltar la tarjeta activa aplicando bordes según la pestaña seleccionada
            let activeBtn = document.getElementById('tab-btn-' + tabName);
            activeBtn.classList.remove('border', 'border-slate-200', 'dark:border-[#4a4b50]');
            
            if(tabName === 'firmas') activeBtn.classList.add('border-2', 'border-brand');
            if(tabName === 'rechazos') activeBtn.classList.add('border-2', 'border-red-500');
            if(tabName === 'olvidados') activeBtn.classList.add('border-2', 'border-amber-500');
        }
    </script>
}