@model QualityDoc.API.Models.DocumentApproval

@{
    ViewData["Title"] = "Evaluar Documento";
    var doc = Model.DocumentVersion?.Document;
}

<div class="max-w-7xl mx-auto mt-6">

    <!-- HEADER Y BOTÓN VOLVER -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6">
        <div>
            <h2 class="text-3xl font-black text-gray-800 tracking-tight flex items-center">
                <i class="fa-solid fa-file-signature text-blue-600 mr-3"></i> Evaluar Documento
            </h2>
            <p class="text-gray-600 font-medium text-lg mt-1">
                @doc?.DocCode - @doc?.DocName (Versión @Model.DocumentVersion?.VersionNum)
            </p>
        </div>
        <div class="mt-4 sm:mt-0">
            <a asp-action="Index" class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-100 font-medium py-2 px-4 rounded shadow-sm transition inline-flex items-center text-sm">
                <i class="fa-solid fa-arrow-left mr-2"></i> Volver a la Bandeja
            </a>
        </div>
    </div>

    <!-- GRID PRINCIPAL A 2 COLUMNAS -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- COLUMNA IZQUIERDA: VISOR DEL PDF (Ocupa 2/3 del espacio) -->
        <div class="lg:col-span-2 bg-white shadow-sm rounded-lg border border-gray-200 overflow-hidden flex flex-col">
            <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
                <span class="text-xs font-bold text-gray-500 uppercase"><i class="fa-solid fa-eye mr-2"></i> Vista Previa del Documento</span>
                <a href="@Model.DocumentVersion?.FilePath" target="_blank" class="text-blue-600 hover:text-blue-800 text-xs font-bold">
                    <i class="fa-solid fa-arrow-up-right-from-square mr-1"></i> Abrir en otra pestaña
                </a>
            </div>
            <!-- Contenedor del Iframe -->
            <div class="w-full h-[600px] bg-gray-100">
                <iframe src="@Model.DocumentVersion?.FilePath" class="w-full h-full border-0"></iframe>
            </div>
        </div>

        <!-- COLUMNA DERECHA: METADATOS Y FORMULARIO DE FIRMA (Ocupa 1/3) -->
        <div class="flex flex-col space-y-6">
            
            <!-- TARJETA DE METADATOS -->
            <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-5">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4 border-b pb-2">Contexto</h3>
                
                <div class="space-y-3">
                    <div>
                        <p class="text-xs text-gray-500 font-medium">Departamento</p>
                        <p class="text-sm font-bold text-gray-900">@doc?.Department?.DeptName</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 font-medium">Categoría ISO</p>
                        <p class="text-sm font-bold text-gray-900">@doc?.Category?.CategoryName</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 font-medium">Motivo del Cambio (Versión @Model.DocumentVersion?.VersionNum)</p>
                        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-2 mt-1 text-xs text-gray-700 italic">
                            "@Model.DocumentVersion?.ChangeDescription"
                        </div>
                    </div>
                </div>
            </div>

            <!-- TARJETA DE DECISIÓN (EL FORMULARIO) -->
            <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-5 border-t-4 border-t-purple-500">
                <h3 class="text-sm font-black text-gray-800 mb-2">Tu Decisión: @Model.StepType</h3>
                <p class="text-xs text-gray-500 mb-4">Revisa el documento detalladamente antes de emitir tu fallo. Esta acción quedará registrada en la bitácora de auditoría.</p>

                <form asp-action="Sign" method="post" id="signForm">
                    <input type="hidden" name="approvalId" value="@Model.ApprovalId" />
                    
                    <div class="mb-4">
                        <label class="block text-xs font-bold text-gray-700 mb-1">Comentarios (Opcional si apruebas, Obligatorio si rechazas)</label>
                        <textarea name="comments" id="commentsBox" rows="3" class="w-full border border-gray-300 rounded p-2 text-sm focus:ring-blue-500 focus:border-blue-500" placeholder="Escribe aquí tus observaciones..."></textarea>
                    </div>

                    <div class="flex flex-col space-y-2">
                        <!-- Botón Aprobar -->
                        <button type="submit" name="decision" value="Approve" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2.5 px-4 rounded shadow-sm transition flex items-center justify-center" onclick="return confirm('¿Estás seguro de APROBAR este documento? Se aplicará tu firma electrónica.');">
                            <i class="fa-solid fa-check-double mr-2"></i> Aprobar Documento
                        </button>

                        <!-- Botón Rechazar -->
                        <button type="submit" name="decision" value="Reject" class="w-full bg-red-100 hover:bg-red-200 text-red-700 font-bold py-2.5 px-4 rounded transition flex items-center justify-center" onclick="return validateRejection();">
                            <i class="fa-solid fa-ban mr-2"></i> Rechazar
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Validación de frontend: Forzar a que pongan un comentario si van a rechazar el documento
        function validateRejection() {
            var comments = document.getElementById('commentsBox').value.trim();
            if (comments === '') {
                alert('Por favor, ingresa un comentario explicando por qué rechazas el documento.');
                document.getElementById('commentsBox').focus();
                return false; // Detiene el envío del formulario
            }
            return confirm('¿Estás seguro de RECHAZAR este documento? Se regresará a estatus de Borrador.');
        }
    </script>
}