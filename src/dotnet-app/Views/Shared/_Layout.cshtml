<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QualityDoc</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        /* Ajuste para que el contenido no quede debajo del sidebar */
        .main-content {
            margin-left: 16rem; /* 256px */
        }
        @@media (max-width: 768px) {
            .main-content { margin-left: 0; }
        }
    </style>
</head>
<body class="bg-gray-100 font-sans leading-normal tracking-normal">

    @{
        // Centralizamos la lógica de roles al inicio del Layout
        var esSuper = User.IsInRole("Super Admin");
        var esAdminEmpresa = User.IsInRole("Admin de Empresa");
        var esLector = User.IsInRole("Lector");
        var esPersonalWorkflow = User.IsInRole("Creador de Doc") || User.IsInRole("Revisor") || User.IsInRole("Aprobador");
    }

    <nav class="fixed w-full z-10 top-0 bg-white border-b border-gray-200 py-3 px-6 flex justify-between items-center">
        <div class="flex items-center">
            <span class="text-blue-600 font-bold text-xl mr-2">QualityDoc</span>
            <span class="text-gray-400 text-sm hidden md:inline">| @User.FindFirst("CompanyName")?.Value</span>
        </div>

        <div class="flex items-center space-x-4">
            <div class="text-right hidden md:block">
                <p class="text-sm font-medium text-gray-700">@User.Identity?.Name</p>
                <p class="text-xs text-gray-500 uppercase">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
            </div>
            
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit" class="bg-gray-100 hover:bg-red-50 text-gray-600 hover:text-red-600 p-2 rounded-full transition" title="Cerrar Sesión">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </button>
            </form>
        </div>
    </nav>

    <aside class="fixed left-0 top-0 h-screen w-64 bg-gray-900 text-gray-300 pt-20 hidden md:block border-r border-gray-800 overflow-y-auto">
        <div class="px-6 mb-8">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Menú Principal</p>
        </div>
        
        <nav class="space-y-1">
            <a asp-controller="Home" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                <i class="fa-solid fa-chart-line w-6"></i>
                <span class="ml-3">Dashboard</span>
            </a>

            @if (esSuper)
            {
                <!-- MENÚ SUPER ADMIN -->
                <div class="px-6 mt-6 mb-2">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Administración Global</p>
                </div>
                <a asp-controller="Companies" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-building w-6"></i>
                    <span class="ml-3">Empresas Clientes</span>
                </a>
                <a asp-controller="Norms" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-scale-balanced w-6"></i>
                    <span class="ml-3">Normativas ISO</span>
                </a>
                <a asp-controller="Roles" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-user-shield w-6"></i>
                    <span class="ml-3">Roles del Sistema</span>
                </a>
            }
            else if (esAdminEmpresa)
            {
                <!-- MENÚ ADMIN DE EMPRESA (QA Manager) -->
                <div class="px-6 mt-6 mb-2">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Configuración ISO</p>
                </div>
                <a asp-controller="Departments" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-sitemap w-6"></i>
                    <span class="ml-3">Departamentos</span>
                </a>
                <a asp-controller="Users" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-users w-6"></i>
                    <span class="ml-3">Personal</span>
                </a>
                <a asp-controller="DocumentCategories" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-folder-tree w-6"></i>
                    <span class="ml-3">Estructura ISO</span>
                </a>

                <div class="px-6 mt-6 mb-2">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Gestión Documental</p>
                </div>
                <a asp-controller="Documents" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-file-signature w-6"></i>
                    <span class="ml-3">Master de Docs</span>
                </a>
                
                @* <!-- 🚀 NUEVO BOTÓN: Mis Firmas para el Admin de Empresa -->
                <a asp-controller="Approvals" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-inbox w-6 text-purple-400"></i>
                    <span class="ml-3 font-bold text-purple-400">Mis Firmas</span>
                </a> *@

                <a asp-controller="DocumentApprovals" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-bars-progress w-6"></i>
                    <span class="ml-3">Flujos Activos</span>
                </a>
            }
            else if (esPersonalWorkflow)
            {
                <!-- MENÚ INGENIEROS (Creadores, Revisores, Aprobadores) -->
                <div class="px-6 mt-6 mb-2">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Operación</p>
                </div>
                <a asp-controller="Documents" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-file-signature w-6"></i>
                    <span class="ml-3">Redactar Docs</span>
                </a>
                
                <!-- 🚀 RUTA ACTUALIZADA: Mis Firmas para Personal -->
                <a asp-controller="Approvals" asp-action="Index" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-inbox w-6 text-purple-400"></i>
                    <span class="ml-3 font-bold text-purple-400">Mis Firmas</span>
                </a>

                <a asp-controller="Documents" asp-action="Library" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-800 hover:text-white transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-book-open-reader w-6"></i>
                    <span class="ml-3">Biblioteca ISO</span>
                </a>
            }
            else if (esLector)
            {
                <!-- MENÚ OPERARIO (Solo enlace externo) -->
                <div class="px-6 mt-6 mb-2">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Piso de Producción</p>
                </div>
                <a href="http://tuservidor-php.com/portal" class="flex items-center px-6 py-3 text-blue-400 hover:bg-gray-800 hover:text-blue-300 transition border-l-4 border-transparent hover:border-blue-500">
                    <i class="fa-solid fa-arrow-up-right-from-square w-6"></i>
                    <span class="ml-3">Portal Operativo</span>
                </a>
            }
        </nav>
    </aside>

    <main class="main-content pt-20 p-8">
        <div class="max-w-7xl mx-auto">
            @RenderBody()
        </div>
    </main>

    <footer class="main-content px-8 py-4 border-t border-gray-200 text-gray-500 text-xs text-center">
        &copy; @DateTime.Now.Year - QualityDoc - Sistema de Trazabilidad IATF 16949 / ISO 9001
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>