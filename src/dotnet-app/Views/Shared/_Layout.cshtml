<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QualityDoc</title>
    
    <script>
        (function() {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
    tailwind.config = {
        darkMode: 'class', 
        theme: {
            extend: {
                fontFamily: {
                    sans: ['Google Sans Flex', 'sans-serif'], 
                },
                colors: {
                    brand: {
                        DEFAULT: 'var(--color-primary)', 
                        hover: 'var(--color-primary-hover)', 
                    }
                }
            }
        }
    }
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .main-content {
            margin-left: 16rem; /* 256px */
        }
        @@media (max-width: 768px) {
            .main-content { margin-left: 0; }
        }
    </style>
</head>
<body class="antialiased font-sans leading-normal tracking-normal bg-[#FAFAFA] dark:bg-[#2a2b2e] transition-colors duration-300">

    @{
        // Roles
        var esSuper = User.IsInRole("Super Admin") || User.IsInRole("Super Administrador");
        var esAdminEmpresa = User.IsInRole("Admin de Empresa");
        var esLector = User.IsInRole("Lector");
        var esPersonalWorkflow = User.IsInRole("Creador de Doc") || User.IsInRole("Revisor") || User.IsInRole("Aprobador");

        // 🧠 HELPER C#: Detecta la página actual para pintar el botón del menú
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        string GetActiveClass(string c, string a = "Index") {
            return (currentController == c && currentAction == a) 
                ? "text-brand dark:text-brand bg-brand/5 dark:bg-brand/10 font-medium border-r-4 border-brand" 
                : "text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-[#2a2b2e] hover:text-brand dark:hover:text-brand border-r-4 border-transparent hover:border-brand/50 transition-colors";
        }
    }

    <nav class="fixed w-full z-20 top-0 bg-white dark:bg-[#323338] border-b border-slate-200 dark:border-[#4a4b50] py-3 px-6 flex justify-between items-center transition-colors duration-300">
        <div class="flex items-center">
            <div class="w-8 h-8 rounded-lg bg-brand/10 flex items-center justify-center mr-3 border border-brand/20">
                <i class="fa-solid fa-file-circle-check text-brand text-sm"></i>
            </div>
            <span class="text-brand font-bold text-xl mr-2">QualityDoc</span>
            <span class="text-slate-400 dark:text-slate-500 text-sm hidden md:inline">| @User.FindFirst("CompanyName")?.Value</span>
        </div>

        <div class="flex items-center space-x-4">
            <button id="themeToggleGlobal" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-[#4a4b50] transition-colors focus:outline-none text-slate-500 dark:text-slate-400">
                <i class="fa-solid fa-moon text-lg" id="moonIconGlobal"></i>
                <i class="fa-solid fa-sun text-lg hidden" id="sunIconGlobal"></i>
            </button>

            <div class="text-right hidden md:block border-l border-slate-200 dark:border-[#4a4b50] pl-4">
                <p class="text-sm font-semibold text-slate-800 dark:text-white">@User.Identity?.Name</p>
                <p class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wide">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
            </div>
            
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit" class="bg-slate-100 dark:bg-[#2a2b2e] hover:bg-red-50 dark:hover:bg-red-900/30 text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 p-2.5 rounded-full transition-colors border border-transparent dark:border-[#4a4b50]" title="Cerrar Sesión">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </button>
            </form>
        </div>
    </nav>

    <aside class="fixed left-0 top-0 h-screen w-64 bg-white dark:bg-[#323338] text-slate-600 dark:text-slate-300 pt-20 hidden md:block border-r border-slate-200 dark:border-[#4a4b50] overflow-y-auto z-10 transition-colors duration-300 shadow-sm">
        <div class="px-6 mb-6 mt-4">
            <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Menú Principal</p>
        </div>
        
        <nav class="space-y-1">
            <a asp-controller="Home" asp-action="Index" class="flex items-center px-6 py-3.5 @GetActiveClass("Home", "Index")">
                <i class="fa-solid fa-chart-line w-6"></i>
                <span class="ml-3">Dashboard</span>
            </a>

            @if (esSuper)
            {
                <div class="px-6 mt-8 mb-3">
                    <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Admin Global</p>
                </div>
                <a asp-controller="Companies" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("Companies")">
                    <i class="fa-solid fa-building w-6"></i>
                    <span class="ml-3">Empresas Clientes</span>
                </a>
                <a asp-controller="Norms" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("Norms")">
                    <i class="fa-solid fa-scale-balanced w-6"></i>
                    <span class="ml-3">Normativas ISO</span>
                </a>
                <a asp-controller="Roles" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("Roles")">
                    <i class="fa-solid fa-user-shield w-6"></i>
                    <span class="ml-3">Roles del Sistema</span>
                </a>
            }
            else if (esAdminEmpresa)
            {
                <div class="px-6 mt-8 mb-3">
                    <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Configuración ISO</p>
                </div>
                <a asp-controller="Departments" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("Departments")">
                    <i class="fa-solid fa-sitemap w-6"></i>
                    <span class="ml-3">Departamentos</span>
                </a>
                <a asp-controller="Users" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("Users")">
                    <i class="fa-solid fa-users w-6"></i>
                    <span class="ml-3">Personal</span>
                </a>
                <a asp-controller="DocumentCategories" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("DocumentCategories")">
                    <i class="fa-solid fa-folder-tree w-6"></i>
                    <span class="ml-3">Estructura ISO</span>
                </a>

                <div class="px-6 mt-8 mb-3">
                    <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Gestión Documental</p>
                </div>
                <a asp-controller="Documents" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("Documents")">
                    <i class="fa-solid fa-file-signature w-6"></i>
                    <span class="ml-3">Master de Docs</span>
                </a>
                <a asp-controller="DocumentApprovals" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("DocumentApprovals")">
                    <i class="fa-solid fa-bars-progress w-6"></i>
                    <span class="ml-3">Flujos Activos</span>
                </a>
            }
            else if (esPersonalWorkflow)
            {
                <div class="px-6 mt-8 mb-3">
                    <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Operación</p>
                </div>
                <a asp-controller="Documents" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("Documents")">
                    <i class="fa-solid fa-file-signature w-6"></i>
                    <span class="ml-3">Redactar Docs</span>
                </a>
                <a asp-controller="Approvals" asp-action="Index" class="flex items-center px-6 py-3 @GetActiveClass("Approvals")">
                    <i class="fa-solid fa-inbox w-6 text-brand"></i>
                    <span class="ml-3 font-bold">Mis Firmas</span>
                </a>
                <a asp-controller="Documents" asp-action="Library" class="flex items-center px-6 py-3 @GetActiveClass("Documents", "Library")">
                    <i class="fa-solid fa-book-open-reader w-6"></i>
                    <span class="ml-3">Biblioteca ISO</span>
                </a>
            }
            else if (esLector)
            {
                <div class="px-6 mt-8 mb-3">
                    <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Piso de Producción</p>
                </div>
                <a href="http://tuservidor-php.com/portal" class="flex items-center px-6 py-3 text-brand dark:text-brand hover:bg-slate-50 dark:hover:bg-[#2a2b2e] transition-colors border-r-4 border-transparent hover:border-brand/50">
                    <i class="fa-solid fa-arrow-up-right-from-square w-6"></i>
                    <span class="ml-3">Portal Operativo</span>
                </a>
            }
        </nav>
    </aside>

    <main class="main-content pt-20 p-8 min-h-[calc(100vh-3rem)]">
        <div class="max-w-7xl mx-auto">
            @RenderBody()
        </div>
    </main>

    <footer class="main-content px-8 py-5 border-t border-slate-200 dark:border-[#4a4b50] text-slate-500 dark:text-slate-400 text-xs text-center transition-colors duration-300 bg-white dark:bg-[#323338]">
        &copy; @DateTime.Now.Year - <span class="font-semibold text-brand">QualityDoc</span> - Sistema de Trazabilidad IATF 16949 / ISO 9001
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const htmlNode = document.documentElement;
            const themeToggleBtn = document.getElementById('themeToggleGlobal');
            const sunIcon = document.getElementById('sunIconGlobal');
            const moonIcon = document.getElementById('moonIconGlobal');

            if (htmlNode.classList.contains('dark')) {
                sunIcon.classList.remove('hidden');
                moonIcon.classList.add('hidden');
            }

            themeToggleBtn.addEventListener('click', () => {
                htmlNode.classList.toggle('dark');
                
                if (htmlNode.classList.contains('dark')) {
                    localStorage.setItem('theme', 'dark');
                    sunIcon.classList.remove('hidden');
                    moonIcon.classList.add('hidden');
                } else {
                    localStorage.setItem('theme', 'light');
                    sunIcon.classList.add('hidden');
                    moonIcon.classList.remove('hidden');
                }
            });
        });
    </script>
</body>
</html>