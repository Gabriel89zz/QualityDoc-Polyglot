@model QualityDoc.API.ViewModels.LoginViewModel
@{
    Layout = null; // No queremos que cargue el menú de navegación aquí
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QualityDoc - Iniciar Sesión</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 flex items-center justify-center h-screen">

    <div class="bg-gray-800 p-8 rounded-lg shadow-xl w-96 border border-gray-700">
        <h2 class="text-2xl font-bold text-white mb-6 text-center">QualityDoc</h2>
        
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4 text-center font-semibold"></div>

        <form asp-controller="Auth" asp-action="Login" method="post" class="space-y-4">
            
            <div>
                <label class="block text-gray-400 text-sm font-bold mb-2">Correo Institucional / Corporativo</label>
                <input asp-for="Email" class="w-full px-3 py-2 bg-gray-700 text-white rounded border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block font-semibold"></span>
            </div>
            
            <div>
                <label class="block text-gray-400 text-sm font-bold mb-2">Contraseña</label>
                <input asp-for="Password" type="password" class="w-full px-3 py-2 bg-gray-700 text-white rounded border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block font-semibold"></span>
            </div>

            <div class="pt-2">
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-2 px-4 rounded shadow-md transition duration-200">
                    Ingresar al Sistema
                </button>
            </div>
        </form>

        <div class="mt-6 text-center border-t border-gray-700 pt-4">
            <p class="text-sm text-gray-400">
                ¿Tu empresa es nueva aquí? <br>
                <a asp-action="Register" class="font-medium text-blue-400 hover:text-blue-300 transition inline-block mt-1">
                    Registra tu cuenta e instala el sistema
                </a>
            </p>
        </div>
    </div>

    @section Scripts {
        @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    }
</body>
</html>