@model QualityDoc.API.Models.DocumentCategory

@{
    ViewData["Title"] = "Detalles de Categoría";
    bool isActive = Model.Status == "Active";
}

<div class="max-w-4xl mx-auto space-y-6 mt-4">
    <nav class="flex mb-4 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
        <ol class="inline-flex items-center space-x-2">
            <li><a asp-action="Index" class="hover:text-brand transition-colors">Categorías</a></li>
            <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
            <li class="text-slate-400 dark:text-slate-500">Ficha Técnica</li>
        </ol>
    </nav>

    <div class="bg-white dark:bg-[#323338] rounded-2xl shadow-sm border border-slate-200 dark:border-[#4a4b50] overflow-hidden transition-colors duration-300">
        
        <div class="@(isActive ? "bg-brand" : "bg-slate-600 dark:bg-slate-800") p-8 flex flex-col md:flex-row justify-between items-center transition-colors duration-300 relative overflow-hidden">
            <div class="absolute right-0 top-0 opacity-10 translate-x-1/4 -translate-y-1/4">
                <i class="fa-solid fa-folder-tree text-9xl text-white"></i>
            </div>

            <div class="flex items-center relative z-10">
                <div class="w-20 h-20 bg-white/20 backdrop-blur-md rounded-2xl border border-white/30 flex justify-center items-center text-4xl font-black text-white shadow-xl mr-6">
                    @Model.CategoryName.Substring(0, 1).ToUpper()
                </div>
                
                <div>
                    <h2 class="text-3xl font-black text-white tracking-tight">@Model.CategoryName</h2>
                    <div class="flex items-center mt-2 text-white/80 text-sm font-medium">
                        <span class="bg-white/20 px-3 py-1 rounded-full border border-white/20">
                            <i class="fa-solid fa-layer-group mr-1.5"></i> Nivel ISO @Model.HierarchyLevel
                        </span>
                    </div>
                </div>
            </div>

            <div class="mt-6 md:mt-0 relative z-10">
                @if (isActive)
                {
                    <span class="bg-green-400/20 text-green-50 px-4 py-2 rounded-full text-xs font-bold border border-green-400/30 backdrop-blur-sm">
                        <i class="fa-solid fa-circle-check mr-1.5"></i> Categoría Vigente
                    </span>
                }
                else
                {
                    <span class="bg-red-400/20 text-red-50 px-4 py-2 rounded-full text-xs font-bold border border-red-400/30 backdrop-blur-sm">
                        <i class="fa-solid fa-ban mr-1.5"></i> Suspendida
                    </span>
                }
            </div>
        </div>

        <div class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
                <div class="space-y-6">
                    <h3 class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-[#4a4b50] pb-2">Identificación de Folios</h3>
                    
                    <div class="flex items-center">
                        <div class="bg-slate-50 dark:bg-[#2a2b2e] p-3 rounded-xl mr-4 text-brand dark:text-brand-light border border-slate-100 dark:border-[#4a4b50] shadow-sm">
                            <i class="fa-solid fa-tag w-5 h-5 text-center"></i>
                        </div>
                        <div>
                            <p class="text-xs text-slate-400 dark:text-slate-500 font-bold uppercase">Prefijo del Documento</p>
                            <p class="text-xl font-mono font-black text-slate-800 dark:text-white">@Model.Prefix-</p>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <div class="bg-slate-50 dark:bg-[#2a2b2e] p-3 rounded-xl mr-4 text-blue-500 dark:text-blue-400 border border-slate-100 dark:border-[#4a4b50] shadow-sm">
                            <i class="fa-solid fa-list-ol w-5 h-5 text-center"></i>
                        </div>
                        <div>
                            <p class="text-xs text-slate-400 dark:text-slate-500 font-bold uppercase">Nivel de Jerarquía</p>
                            <p class="text-sm font-bold text-slate-800 dark:text-white">Grado @Model.HierarchyLevel (Pirámide Documental)</p>
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <h3 class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-[#4a4b50] pb-2">Propósito</h3>
                    <div class="bg-slate-50 dark:bg-[#2a2b2e] p-4 rounded-xl border border-slate-200 dark:border-[#4a4b50] text-sm text-slate-600 dark:text-slate-300 leading-relaxed italic">
                        <i class="fa-solid fa-quote-left text-slate-200 dark:text-[#4a4b50] text-2xl mr-2"></i>
                        @(string.IsNullOrEmpty(Model.Description) ? "Sin descripción técnica asignada." : Model.Description)
                    </div>
                </div>
            </div>

            <h3 class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest border-b border-slate-100 dark:border-[#4a4b50] pb-2 mb-4">Registro de Auditoría</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-slate-50 dark:bg-[#2a2b2e] p-4 rounded-xl border border-slate-100 dark:border-transparent">
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-bold uppercase mb-1">Creado el</p>
                    <p class="text-sm text-slate-800 dark:text-slate-300">
                        <i class="fa-regular fa-calendar mr-2 text-slate-400"></i> 
                        @Model.CreatedAt.ToLocalTime().ToString("dd MMMM, yyyy - HH:mm")
                    </p>
                </div>

                <div class="bg-slate-50 dark:bg-[#2a2b2e] p-4 rounded-xl border border-slate-100 dark:border-transparent">
                    <p class="text-xs text-slate-400 dark:text-slate-500 font-bold uppercase mb-1">Última actualización</p>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <p class="text-sm text-slate-800 dark:text-slate-300">
                            <i class="fa-regular fa-clock mr-2 text-slate-400"></i> 
                            @Model.UpdatedAt.Value.ToLocalTime().ToString("dd MMMM, yyyy - HH:mm")
                        </p>
                    }
                    else
                    {
                        <p class="text-sm text-slate-400 italic">Sin modificaciones posteriores.</p>
                    }
                </div>
            </div>
        </div>

        <div class="bg-slate-50 dark:bg-[#2a2b2e] p-6 border-t border-slate-100 dark:border-[#4a4b50] flex flex-col sm:flex-row justify-between items-center transition-colors duration-300 gap-4">
            <a asp-action="Index" class="text-slate-500 hover:text-slate-800 dark:hover:text-white text-sm font-bold flex items-center transition">
                <i class="fa-solid fa-arrow-left mr-2"></i> Volver al listado
            </a>
            
            <div class="flex items-center space-x-3 w-full sm:w-auto">
                @if (isActive)
                {
                    <form asp-action="Delete" asp-route-id="@Model.CategoryId" method="post" class="m-0 w-full sm:w-auto">
                        <button type="submit" class="w-full sm:w-auto px-6 py-2.5 bg-white dark:bg-[#323338] border border-red-200 dark:border-red-900/50 text-red-600 dark:text-red-400 rounded-xl text-sm font-bold hover:bg-red-50 dark:hover:bg-red-900/20 transition flex items-center justify-center" onclick="return confirm('¿Estás seguro de suspender esta categoría documental?');">
                            <i class="fa-solid fa-ban mr-2"></i> Suspender
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="Reactivate" asp-route-id="@Model.CategoryId" method="post" class="m-0 w-full sm:w-auto">
                        <button type="submit" class="w-full sm:w-auto px-6 py-2.5 bg-white dark:bg-[#323338] border border-green-200 dark:border-green-900/50 text-green-600 dark:text-green-400 rounded-xl text-sm font-bold hover:bg-green-50 dark:hover:bg-green-900/20 transition flex items-center justify-center" onclick="return confirm('¿Deseas reactivar esta categoría?');">
                            <i class="fa-solid fa-arrow-rotate-left mr-2"></i> Restaurar
                        </button>
                    </form>
                }
                
                <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="w-full sm:w-auto bg-brand hover:bg-brand-hover text-white text-sm font-bold py-2.5 px-6 rounded-xl shadow-md shadow-brand/20 transition flex items-center justify-center">
                    <i class="fa-solid fa-pen-to-square mr-2"></i> Editar Categoría
                </a>
            </div>
        </div>
    </div>
</div>