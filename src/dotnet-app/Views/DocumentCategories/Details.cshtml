@model QualityDoc.API.Models.DocumentCategory

@{
    ViewData["Title"] = "Detalles de Categoría";
    bool isActive = Model.Status == "Active";
}

<div class="max-w-5xl mx-auto mt-8 mb-10">
    
    <!-- CONTENEDOR PRINCIPAL -->
    <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden flex flex-col">
        
        <!-- 1. ENCABEZADO DINÁMICO (Azul si Activa, Gris si Inactiva) -->
        <div class="@(isActive ? "bg-blue-600" : "bg-slate-600") px-8 py-8 flex justify-between items-start transition-colors duration-300">
            <div class="flex items-center">
                <div class="w-20 h-20 bg-white/20 rounded-2xl border border-white/10 flex justify-center items-center text-4xl font-extrabold text-white shadow-inner mr-6">
                    @Model.CategoryName.Substring(0, 1).ToUpper()
                </div>
                
                <div>
                    <h2 class="text-3xl font-bold text-white tracking-tight">@Model.CategoryName</h2>
                    <div class="flex items-center mt-1.5 @(isActive ? "text-blue-100" : "text-slate-200") text-sm">
                        <i class="fa-solid fa-layer-group mr-2 opacity-80"></i>
                        <span>
                            Nivel @Model.HierarchyLevel - 
                            @(Model.HierarchyLevel == 1 ? "Manuales/Políticas" :
                              Model.HierarchyLevel == 2 ? "Procedimientos" :
                              Model.HierarchyLevel == 3 ? "Instructivos" : "Formatos/Registros")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Badge de Estado en la esquina superior derecha -->
            @if (isActive)
            {
                <span class="bg-blue-500/50 text-white border border-blue-400/50 text-xs font-semibold px-4 py-1.5 rounded-full shadow-sm">
                    Categoría Activa
                </span>
            }
            else
            {
                <span class="bg-red-500/80 text-white border border-red-400/50 text-xs font-semibold px-4 py-1.5 rounded-full shadow-sm">
                    Categoría Inactiva
                </span>
            }
        </div>

        <!-- 2. CUERPO DE LA TARJETA -->
        <div class="p-8">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 mb-10">
                <!-- Columna Izquierda -->
                <div>
                    <h3 class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-4">Clasificación</h3>
                    <div class="flex items-start mb-5">
                        <div class="bg-gray-50 p-2 rounded text-gray-500 mr-3 border border-gray-100">
                            <i class="fa-solid fa-barcode w-4 text-center"></i>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-0.5">Prefijo de Codificación</p>
                            <p class="font-mono font-bold text-gray-900 text-base">@Model.Prefix</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <div class="bg-gray-50 p-2 rounded text-gray-500 mr-3 border border-gray-100">
                            <i class="fa-solid fa-align-left w-4 text-center"></i>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-0.5">Descripción de Uso</p>
                            <p class="font-medium text-gray-800 text-sm leading-snug">
                                @(!string.IsNullOrEmpty(Model.Description) ? Model.Description : "No se especificó una descripción para esta categoría.")
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Columna Derecha -->
                <div>
                    <h3 class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-4">Normatividad</h3>
                    <div class="flex items-start">
                        <div class="bg-gray-50 p-2 rounded text-gray-500 mr-3 border border-gray-100">
                            <i class="fa-solid fa-shield-halved w-4 text-center"></i>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-0.5">Norma Aplicable</p>
                            <p class="font-bold text-gray-900 text-base">
                                @(Model.Norm != null ? Model.Norm.NormName : "Genérica (Todas)")
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <h3 class="text-sm font-bold text-gray-900 mb-4">Auditoría de Registro</h3>
            <hr class="border-gray-100 mb-4" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <!-- Tarjeta 1: Fecha de Alta -->
                <div class="bg-[#fafafa] border border-gray-100 rounded-lg p-5">
                    <p class="text-[11px] text-gray-400 font-semibold uppercase tracking-wider mb-3">Fecha de Alta</p>
                    <div class="space-y-2.5 text-sm text-gray-700">
                        <div class="flex items-center">
                            <i class="fa-regular fa-calendar w-5 text-gray-400 text-center mr-2"></i>
                            <span>@Model.CreatedAt.ToLocalTime().ToString("dd MMMM, yyyy - HH:mm")</span>
                        </div>
                        <div class="flex items-center">
                            <i class="fa-solid fa-user-shield w-5 text-gray-400 text-center mr-2"></i>
                            <span>Registrado por: 
                                <span class="font-bold text-black">
                                    @(Model.CreatedBy == 1 ? "Sistema" : Model.CreatedByNavigation?.FullName ?? "Usuario Desconocido")
                                </span>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta 2: Última Actualización -->
                <div class="bg-[#fafafa] border border-gray-100 rounded-lg p-5">
                    <p class="text-[11px] text-gray-400 font-semibold uppercase tracking-wider mb-3">Última Actualización</p>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="space-y-2.5 text-sm text-gray-700">
                            <div class="flex items-center">
                                <i class="fa-regular fa-calendar w-5 text-gray-400 text-center mr-2"></i>
                                <span>@Model.UpdatedAt.Value.ToLocalTime().ToString("dd MMMM, yyyy - HH:mm")</span>
                            </div>
                            <div class="flex items-center">
                                <i class="fa-solid fa-user-pen w-5 text-gray-400 text-center mr-2"></i>
                                <span>Actualizado por: 
                                    <span class="font-bold text-black">
                                        @(Model.UpdatedBy == 1 ? "Sistema" : Model.UpdatedByNavigation?.FullName ?? "Usuario Desconocido")
                                    </span>
                                </span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="h-full flex items-center pb-2">
                            <p class="text-[14px] text-gray-500 italic">Sin cambios registrados.</p>
                        </div>
                    }
                </div>

                <!-- 🚀 NUEVO: Detalles de Suspensión -->
                @if (!isActive)
                {
                    <div class="bg-red-50 border border-red-100 rounded-lg p-5 md:col-span-2 mt-2">
                        <p class="text-[11px] text-red-500 font-semibold uppercase tracking-wider mb-3">Detalles de Suspensión</p>
                        <div class="space-y-2.5 text-sm text-red-800">
                            <div class="flex items-center">
                                <i class="fa-solid fa-calendar-xmark w-5 text-red-400 text-center mr-2"></i>
                                <span>@(Model.DeletedAt?.ToLocalTime().ToString("dd MMMM, yyyy - HH:mm") ?? "Fecha desconocida")</span>
                            </div>
                            <div class="flex items-center">
                                <i class="fa-solid fa-user-slash w-5 text-red-400 text-center mr-2"></i>
                                <span>Suspendido por: 
                                    <span class="font-bold text-black">
                                        @(Model.DeletedByNavigation?.FullName ?? "Sistema")
                                    </span>
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- 3. FOOTER DE ACCIONES -->
            <hr class="border-gray-100 mb-6" />
            
            <div class="flex justify-between items-center">
                <a asp-action="Index" class="text-gray-500 hover:text-gray-800 font-semibold text-sm transition flex items-center">
                    <i class="fa-solid fa-arrow-left mr-2"></i> Volver al listado
                </a>
                
                <div class="flex space-x-3">
                    @if (isActive)
                    {
                        <!-- Botón Suspender convertido a POST -->
                        <form asp-action="Delete" asp-route-id="@Model.CategoryId" method="post" class="m-0">
                            <button type="submit" class="px-6 py-2.5 bg-white border border-red-200 text-red-600 rounded-lg text-sm font-bold hover:bg-red-50 transition flex items-center" onclick="return confirm('¿Estás seguro de suspender esta categoría documental?');">
                                <i class="fa-solid fa-ban mr-2"></i> Suspender
                            </button>
                        </form>
                    }
                    else
                    {
                        <!-- Botón Reactivar convertido a POST -->
                        <form asp-action="Reactivate" asp-route-id="@Model.CategoryId" method="post" class="m-0">
                            <button type="submit" class="px-6 py-2.5 bg-white border border-green-200 text-green-600 rounded-lg text-sm font-bold hover:bg-green-50 transition flex items-center" onclick="return confirm('¿Deseas volver a activar esta categoría documental?');">
                                <i class="fa-solid fa-arrow-rotate-left mr-2"></i> Restaurar
                            </button>
                        </form>
                    }
                    <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700 shadow-md transition flex items-center">
                        <i class="fa-solid fa-pen-to-square mr-2"></i> Editar Categoría
                    </a>
                </div>
            </div>
            
        </div>
    </div>
</div>