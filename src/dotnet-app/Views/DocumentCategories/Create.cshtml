@model QualityDoc.API.Models.DocumentCategory

@{
    ViewData["Title"] = "Nueva Categoría Documental";
}

<div class="max-w-3xl mx-auto mt-8">
    <!-- Tarjeta del Formulario -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        
        <!-- Cabecera -->
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-100">
            <h2 class="text-xl font-bold text-gray-800">
                <i class="fa-solid fa-folder-plus text-blue-600 mr-2"></i> Registrar Nueva Categoría
            </h2>
            <p class="text-sm text-gray-500 mt-1">
                Define una nueva clasificación para la pirámide documental de tu empresa.
            </p>
        </div>

        <!-- Cuerpo del Formulario -->
        <form asp-action="Create" class="p-6 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm font-bold bg-red-50 p-3 rounded mb-4"></div>

            <!-- Fila 1: Nombre de la Categoría (Ancho completo) -->
            <div>
                <label asp-for="CategoryName" class="block text-sm font-bold text-gray-700 mb-1">Nombre de la Categoría *</label>
                <input asp-for="CategoryName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" placeholder="Ej. Procedimientos Operativos" required />
                <span asp-validation-for="CategoryName" class="text-xs text-red-500 mt-1"></span>
            </div>

            <!-- Fila 2: Grid de 3 columnas para datos técnicos -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                
                <!-- Columna: Prefijo ISO -->
                <div>
                    <label asp-for="Prefix" class="block text-sm font-bold text-gray-700 mb-1">Prefijo ISO *</label>
                    <input asp-for="Prefix" class="w-full px-4 py-2 border border-gray-300 rounded-lg font-mono uppercase focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" placeholder="PRO" maxlength="5" style="text-transform: uppercase;" required />
                    <p class="text-xs text-gray-400 mt-1"><i class="fa-solid fa-circle-info"></i> Usado para generar el código (Ej. PRO-01).</p>
                    <span asp-validation-for="Prefix" class="text-xs text-red-500 mt-1"></span>
                </div>

                <!-- Columna: Nivel Jerárquico -->
                <div>
                    <label asp-for="HierarchyLevel" class="block text-sm font-bold text-gray-700 mb-1">Nivel Jerárquico *</label>
                    <select asp-for="HierarchyLevel" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition bg-white" required>
                        <option value="">-- Seleccionar --</option>
                        <option value="1">Nivel 1 (Manuales / Políticas)</option>
                        <option value="2">Nivel 2 (Procedimientos)</option>
                        <option value="3">Nivel 3 (Instructivos de Trabajo)</option>
                        <option value="4">Nivel 4 (Formatos / Registros)</option>
                    </select>
                    <p class="text-xs text-gray-400 mt-1"><i class="fa-solid fa-layer-group"></i> Nivel en la pirámide de calidad.</p>
                    <span asp-validation-for="HierarchyLevel" class="text-xs text-red-500 mt-1"></span>
                </div>

                <!-- Columna: Norma (Opcional) -->
                <div>
                    <label asp-for="NormId" class="block text-sm font-bold text-gray-700 mb-1">Aplica para Norma</label>
                    <select asp-for="NormId" asp-items="ViewBag.Norms" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition bg-white">
                        <option value="">-- Genérica (Aplica a todas) --</option>
                    </select>
                    <p class="text-xs text-gray-400 mt-1"><i class="fa-solid fa-book"></i> Déjalo en blanco si es universal.</p>
                    <span asp-validation-for="NormId" class="text-xs text-red-500 mt-1"></span>
                </div>
            </div>

            <!-- Fila 3: Descripción (Ancho completo) -->
            <div>
                <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1">Descripción (Opcional)</label>
                <textarea asp-for="Description" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition resize-none" placeholder="Describe brevemente qué tipo de documentos deben subirse en esta categoría..."></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-500 mt-1"></span>
            </div>

            <hr class="border-gray-100" />

            <!-- Fila 4: Botones de Acción -->
            <div class="flex justify-end space-x-3 pt-2">
                <a asp-action="Index" class="px-5 py-2.5 border border-gray-300 text-gray-700 rounded-lg text-sm font-bold hover:bg-gray-50 transition">
                    Cancelar
                </a>
                <button type="submit" class="px-5 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700 shadow-md transition flex items-center">
                    <i class="fa-solid fa-check mr-2"></i> Guardar Categoría
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}