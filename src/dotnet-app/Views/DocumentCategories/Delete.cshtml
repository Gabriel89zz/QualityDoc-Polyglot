@model QualityDoc.API.Models.DocumentCategory

@{
    ViewData["Title"] = "Eliminar Categoría";
}

<div class="max-w-2xl mx-auto mt-8">
    <!-- Tarjeta de Advertencia -->
    <div class="bg-white rounded-xl shadow-sm border border-red-200 overflow-hidden">
        
        <!-- Cabecera de Peligro -->
        <div class="bg-red-50 px-6 py-5 border-b border-red-100 flex items-center">
            <div class="bg-red-100 p-3 rounded-full mr-4 text-red-600 shadow-sm">
                <i class="fa-solid fa-triangle-exclamation text-xl"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-red-800">Confirmar Eliminación</h2>
                <p class="text-sm text-red-600 mt-0.5">
                    Estás a punto de dar de baja esta categoría documental.
                </p>
            </div>
        </div>

        <!-- Detalles de la Categoría -->
        <div class="p-6">
            <p class="text-gray-700 mb-6 text-sm">
                Por favor, revisa los detalles antes de continuar. Al darla de baja, <span class="font-bold">ya no se podrán clasificar nuevos documentos</span> con este prefijo. Sin embargo, los documentos históricos asociados se mantendrán intactos para futuras auditorías de calidad.
            </p>

            <!-- Caja de Resumen -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-5 mb-6">
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-5">
                    <div>
                        <dt class="text-xs font-bold text-gray-500 uppercase tracking-wide">Nombre de la Categoría</dt>
                        <dd class="mt-1 text-base font-semibold text-gray-900">@Model.CategoryName</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-bold text-gray-500 uppercase tracking-wide">Prefijo ISO</dt>
                        <dd class="mt-1 text-base font-mono font-bold text-gray-700 bg-gray-200 inline-block px-2 py-0.5 rounded">
                            @Model.Prefix
                        </dd>
                    </div>
                    <div>
                        <dt class="text-xs font-bold text-gray-500 uppercase tracking-wide">Nivel Jerárquico</dt>
                        <dd class="mt-1 text-sm font-medium text-gray-800">Nivel @Model.HierarchyLevel</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-bold text-gray-500 uppercase tracking-wide">Norma Aplicable</dt>
                        <dd class="mt-1 text-sm font-medium text-gray-800">
                            @if (Model.Norm != null)
                            {
                                <i class="fa-solid fa-book-bookmark text-gray-400 mr-1"></i> @Model.Norm.NormName
                            }
                            else
                            {
                                <span class="italic text-gray-500">Genérica (Aplica a todas)</span>
                            }
                        </dd>
                    </div>
                </dl>
            </div>

            <!-- Formulario de Confirmación -->
            <form asp-action="Delete" class="flex justify-end space-x-3 mt-4">
                <!-- ID Oculto para procesar la baja -->
                <input type="hidden" asp-for="CategoryId" />
                
                <a asp-action="Index" class="px-5 py-2.5 border border-gray-300 text-gray-700 rounded-lg text-sm font-bold hover:bg-gray-50 transition">
                    Cancelar
                </a>
                <button type="submit" class="px-5 py-2.5 bg-red-600 text-white rounded-lg text-sm font-bold hover:bg-red-700 shadow-md transition flex items-center">
                    <i class="fa-solid fa-trash-can mr-2"></i> Sí, dar de baja
                </button>
            </form>
        </div>
    </div>
</div>